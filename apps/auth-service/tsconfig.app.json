{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/auth-service",
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": false,
    "tsBuildInfoFile": "../../dist/apps/auth-service/.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@aramo/common": ["../../dist/libs/common/src/index.d.ts"],
      "@aramo/auth": ["../../dist/libs/auth/src/index.d.ts"],
      "@aramo/identity": ["../../dist/libs/identity/src/index.d.ts"],
      "@aramo/auth-storage": ["../../dist/libs/auth-storage/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/tests/**/*", "**/*.spec.ts"]
}
