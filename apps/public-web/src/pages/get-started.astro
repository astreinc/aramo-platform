---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkspaceRequestForm from '../components/WorkspaceRequestForm.tsx';
---

<BaseLayout
  title="Get started — Aramo"
  description="Request a workspace on Aramo. Tell us about your desk and we will set you up — or email hello@aramo.ai."
>
  <!-- Hero + form -->
  <section class="section hero">
    <div class="container">
      <div class="split">
        <div class="split__body">
          <span class="eyebrow">Get started</span>
          <h1 class="hero__display">Put proof behind your next submittal.</h1>
          <p class="hero__sub">
            Tell us about your desk and we will set up a workspace — isolated to
            your firm from the first day.
          </p>
          <p class="secondary-line">
            Prefer email? Write to&#32;
            <a href="mailto:hello@aramo.ai">hello@aramo.ai</a>.
          </p>
        </div>
        <div class="split__visual">
          <WorkspaceRequestForm client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="section section--bleed section--alt">
    <div class="container">
      <span class="eyebrow">What to expect</span>
      <h2 class="section-title">Getting set up.</h2>
      <ol class="steps">
        <li class="steps__item">
          <span class="steps__n" aria-hidden="true">1</span>
          <div>
            <p class="steps__title">Send the request</p>
            <p class="steps__body">
              Fill in the form with your name, work email, firm, and a line
              about how your team works today.
            </p>
          </div>
        </li>
        <li class="steps__item">
          <span class="steps__n" aria-hidden="true">2</span>
          <div>
            <p class="steps__title">We set up your workspace</p>
            <p class="steps__body">
              Isolated to your firm from the first day — your data never feeds
              another desk.
            </p>
          </div>
        </li>
        <li class="steps__item">
          <span class="steps__n" aria-hidden="true">3</span>
          <div>
            <p class="steps__title">Submit with proof</p>
            <p class="steps__body">
              Your first submittals carry their evidence — clients see why.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .secondary-line {
    font-size: var(--fs-14);
    color: var(--c-text-subtle);
    margin: var(--sp-4) 0 0;
  }
  .steps {
    list-style: none;
    margin: var(--sp-6) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    max-width: 46rem;
  }
  .steps__item {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    padding: var(--sp-5);
    box-shadow: var(--sh-1);
  }
  .steps__n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: var(--c-accent-soft);
    color: var(--c-accent-active);
    font-weight: var(--fw-semibold);
    flex: none;
  }
  .steps__title {
    margin: 0;
    font-weight: var(--fw-semibold);
    color: var(--c-text);
  }
  .steps__body {
    margin: 2px 0 0;
    color: var(--c-text-muted);
  }
</style>
