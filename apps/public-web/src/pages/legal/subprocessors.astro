    <tbody>
      <tr>
        <td>Amazon Web Services</td>
        <td>Hosting, storage, email delivery, and identity services</td>
        <td>United States</td>
      </tr>
      <tr>
        <td>Anthropic</td>
        <td>AI-assisted processing</td>
        <td>United States</td>
      </tr>
      <tr>
        <td>Google</td>
        <td>Location and places services</td>
