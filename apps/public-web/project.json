{
  "name": "public-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/public-web/src",
  "projectType": "application",
  "tags": ["scope:public"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/public-web/dist"],
      "options": {
        "command": "astro build --root apps/public-web"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro dev --root apps/public-web"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro check --root apps/public-web"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/public-web/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root apps/public-web"
      }
    }
  }
}
