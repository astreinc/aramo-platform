{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/api",
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": false,
    "tsBuildInfoFile": "../../dist/apps/api/.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@aramo/common": ["../../dist/libs/common/src/index.d.ts"],
      "@aramo/auth": ["../../dist/libs/auth/src/index.d.ts"],
      "@aramo/authorization": ["../../dist/libs/authorization/src/index.d.ts"],
      "@aramo/consent": ["../../dist/libs/consent/src/index.d.ts"],
      "@aramo/engagement": ["../../dist/libs/engagement/src/index.d.ts"],
      "@aramo/entitlement": ["../../dist/libs/entitlement/src/index.d.ts"],
      "@aramo/ingestion": ["../../dist/libs/ingestion/src/index.d.ts"],
      "@aramo/matching": ["../../dist/libs/matching/src/index.d.ts"],
      "@aramo/examination": ["../../dist/libs/examination/src/index.d.ts"],
      "@aramo/outbox-publisher": ["../../dist/libs/outbox-publisher/src/index.d.ts"],
      "@aramo/portal": ["../../dist/libs/portal/src/index.d.ts"],
      "@aramo/skills-taxonomy": ["../../dist/libs/skills-taxonomy/src/index.d.ts"],
      "@aramo/submittal": ["../../dist/libs/submittal/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/tests/**/*", "**/*.spec.ts"]
}
