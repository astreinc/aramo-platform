{
  "name": "public-intake",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/public-intake/src",
  "projectType": "application",
  "tags": ["scope:public"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [],
      "options": {
        "outputPath": "dist/apps/public-intake",
        "main": "apps/public-intake/src/main.ts",
        "tsConfig": "apps/public-intake/tsconfig.app.json"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/public-intake/src/main.js"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/public-intake/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root apps/public-intake"
      }
    }
  }
}
