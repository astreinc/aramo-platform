{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/portal-web",
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "tsBuildInfoFile": "../../dist/apps/portal-web/.tsbuildinfo",
    "types": ["node", "vite/client"],
    "paths": {
      "@aramo/fe-foundation": ["../../dist/libs/fe-foundation/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/test-setup.ts",
    "src/portal-negative-control/**"
  ]
}
