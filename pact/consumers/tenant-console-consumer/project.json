{
  "name": "tenant-console-consumer-pact",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "pact/consumers/tenant-console-consumer/src",
  "projectType": "library",
  "tags": ["pact-consumer"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["pact/consumers/tenant-console-consumer/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Pact contract tests are excluded from the aggregate test target. Run nx pact-test tenant-console-consumer-pact (or invoke vitest directly) to execute them.'"
      }
    },
    "pact-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root pact/consumers/tenant-console-consumer"
      }
    }
  }
}
