# Aramo single-box — daily Postgres backup schedule (Single-Box Directive 3 §B).
# Fires aramo-pg-backup.service once a day. Persistent=true catches up a missed
# run if the box was off at the scheduled time (e.g. after a reboot).

[Unit]
Description=Daily Aramo box Postgres backup → S3

[Timer]
OnCalendar=*-*-* 03:30:00
Persistent=true
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
