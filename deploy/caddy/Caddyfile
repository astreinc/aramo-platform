# Aramo — Single-Box prod front-door (Directive 1 + Subdomain-Identity A).
#
# One origin, path-routed: Caddy serves the ats-web static SPA at / and
# reverse-proxies the API surfaces to the container-internal backends. Because
# the whole app is same-origin, the FE calls RELATIVE paths (/v1, /auth) — no
# CORS, no absolute-URL baking, no per-env rebuild (sidesteps the Vite
# build-time-URL problem entirely; the FE's ApiClient already defaults to an
# empty base, see libs/fe-foundation/src/api/client.ts).
#
# TLS is parameterized by env vars (set in docker-compose.prod.yml from the real
# .env; see .env.prod.example) so the SAME Caddyfile runs both locally and on the
# box:
#   CADDY_SITE_ADDRESS — the address Caddy answers on.
#       local : localhost        (no public domain needed)
#       box   : *.aramo.ai       (Subdomain-Identity A — ANY tenant subdomain;
#                                 a single wildcard host, NOT a per-tenant block.
#                                 astre.aramo.ai is subsumed here so Astre flows
#                                 through the SAME on-demand path as tenant #50.)
#   CADDY_TLS          — the `tls` directive argument.
#       local : internal         (Caddy's local CA — trusted on the laptop)
#       box   : admin@aramo.ai   (an ACME email → Caddy auto-provisions AND
#                                 auto-renews real Let's Encrypt certs)
#   CADDY_TLS_ONDEMAND — the optional on-demand toggle inside the tls block.
#       local : (unset/empty)    → no on-demand; localhost gets one internal cert
#       box   : on_demand        → Subdomain-Identity A: Caddy mints a per-host
#                                  cert JUST-IN-TIME on first request, but only
#                                  after the ask-endpoint validates the host
#                                  against the tenant table (see the global
#                                  on_demand_tls block below). Keeps HTTP-01 — no
#                                  DNS-01, no Route53 plugin, no Route53 creds.
#
# Locally the full stack runs + is testable with NO public domain (Caddy local
# CA over https://localhost, NO on-demand). On the box the same config serves
# every <slug>.aramo.ai with a tenant-validated on-demand cert — the honest
# box-only boundary per §D (real Let's Encrypt needs the public domain + ACME
# challenge, verified on the box, not locally).
{
	# Subdomain-Identity A — on-demand TLS ask-endpoint (global option). Caddy
	# calls this URL BEFORE issuing an on-demand cert, forwarding the requested
	# host as ?domain=<host>; it issues ONLY on a 2xx. So the tenant table is the
	# single source of truth for "is this a valid subdomain": a host gets a cert
	# iff a real active tenant owns its slug (apps/api PublicTenantCertController →
	# TenantService.findActiveBySlug). The default points at the compose-internal
	# api service (no new required env var); override via CADDY_ASK_URL if needed.
	#
	# This block is ALWAYS present but is ONLY consulted by a site that opts into
	# `on_demand` — so it is inert locally (the localhost site below leaves
	# CADDY_TLS_ONDEMAND empty and never asks).
	on_demand_tls {
		ask {$CADDY_ASK_URL:http://api:3000/v1/tenants/cert-eligible}
	}
}

{$CADDY_SITE_ADDRESS:localhost} {
	tls {$CADDY_TLS:internal} {
		# Empty locally (one static internal/ACME cert); `on_demand` on the box
		# (per-host, tenant-validated via the ask-endpoint above).
		{$CADDY_TLS_ONDEMAND:}
	}

	# API + auth surfaces → the container-internal backends (compose service
	# names). These ports are NEVER published to the host — Caddy is the only
	# ingress. reverse_proxy forwards the full request path unchanged, so
	# /v1/... and /auth/... reach the services exactly as the FE sent them.
	handle /v1/* {
		reverse_proxy api:3000
	}
	handle /auth/* {
		reverse_proxy auth-service:3001
	}
	# The JWKS document (auth-service's only /.well-known route). Matched by
	# exact path — NOT /.well-known/* — so /.well-known/acme-challenge/* stays
	# free for Caddy's own Let's Encrypt HTTP-01 challenge on the box (on-demand
	# certs are issued via HTTP-01 too — no DNS-01).
	handle /.well-known/jwks.json {
		reverse_proxy auth-service:3001
	}

	# Everything else: the ats-web static SPA baked into this image at /srv/ats
	# (Inc-3 PR-3.3 re-path: was /srv; platform-web now occupies /srv/admin).
	# The try_files …/index.html fallback gives client-side routing its SPA
	# entry point (deep links like /talent/123 resolve to index.html and the
	# React router takes over).
	handle {
		root * /srv/ats
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd
}

# ─────────────────────────────────────────────────────────────────────────────
# Inc-3 PR-3.3 — the platform console site block (admin.aramo.ai), Ruling R14.
#
# A DEDICATED, explicit host block — NOT the on-demand wildcard. On the box the
# explicit admin.aramo.ai block wins over the *.aramo.ai wildcard (Caddy routes
# most-specific-host-first), so the platform console gets an ORDINARY ACME cert
# provisioned the normal way (HTTP-01 at first request), with NO on_demand and
# the tenant ask-endpoint NEVER involved (R14: the platform host must never
# depend on — or be gated by — the tenant table's cert-eligibility check).
#
# TLS reuses {$CADDY_TLS} (local: `internal` → Caddy's local CA covers
# admin.localhost; box: `admin@aramo.ai` → ordinary Let's Encrypt) but OMITS the
# on_demand toggle — so admin.aramo.ai is a fixed, known host, not a per-request
# mint.
#
#   CADDY_ADMIN_ADDRESS — the address the platform console answers on.
#       local : admin.localhost   (distinct from the wildcard's `localhost`;
#                                  Caddy's internal CA trusts *.localhost, so a
#                                  local dual-root bring-up needs no public DNS)
#       box   : admin.aramo.ai
{$CADDY_ADMIN_ADDRESS:admin.localhost} {
	tls {$CADDY_TLS:internal}

	# Auth surface → auth-service (the platform console's OAuth/PKCE round-trip;
	# host-derivation in PR-3.1 makes admin.aramo.ai its own redirect base).
	handle /auth/* {
		reverse_proxy auth-service:3001
	}
	# Platform API → platform-admin (the /platform/* surface, PR-3.2 contract).
	handle /platform/* {
		reverse_proxy platform-admin:3002
	}
	# JWKS document — exact path (see wildcard block for the acme-challenge note).
	handle /.well-known/jwks.json {
		reverse_proxy auth-service:3001
	}

	# NO `/v1` route — DELIBERATE (R14). The platform host cannot reach the
	# tenant api even by misconfiguration: there is simply no reverse_proxy to
	# api:3000 here, so a stray /v1 request falls through to the SPA fallback
	# (index.html), never to tenant data.

	# Everything else: the platform-web static SPA baked into this image at
	# /srv/admin. Same SPA-fallback shape as the tenant console.
	handle {
		root * /srv/admin
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd
}

# ─────────────────────────────────────────────────────────────────────────────
# Portal P1 PR-3 — the talent-facing portal site block (candidate.aramo.ai).
#
# A DEDICATED, explicit host block modeled on admin.aramo.ai — NOT the on-demand
# wildcard. The explicit block wins over *.aramo.ai (most-specific-host-first),
# so the portal host gets an ORDINARY ACME cert (HTTP-01 at first request), with
# NO on_demand and the tenant ask-endpoint NEVER involved (same R14 posture as
# the admin block: a platform-owned front door is never gated by the tenant
# cert-eligibility check). TLS reuses {$CADDY_TLS} (local `internal`; box
# `admin@aramo.ai` → Let's Encrypt) and OMITS the on_demand toggle.
#
#   CADDY_PORTAL_ADDRESS — the address the portal answers on.
#       local : portal.localhost   (Caddy's internal CA trusts *.localhost; the
#                                   local default uses the internal name per
#                                   Amendment v1.1 — only the PUBLIC host keeps
#                                   the human word)
#       box   : candidate.aramo.ai
{$CADDY_PORTAL_ADDRESS:portal.localhost} {
	tls {$CADDY_TLS:internal}

	# Portal API → api. SCOPED to /v1/portal/* ONLY (the R14 discipline, portal
	# direction): the block exposes just the portal prefix, never a general /v1/*
	# proxy, so no other tenant-api surface is reachable from this host.
	handle /v1/portal/* {
		reverse_proxy api:3000
	}
	# Auth surface → auth-service (the passwordless request-link / consume round
	# trip; host-derivation makes candidate.aramo.ai its own redirect base).
	handle /auth/* {
		reverse_proxy auth-service:3001
	}
	# JWKS document — exact path (see wildcard block for the acme-challenge note).
	handle /.well-known/jwks.json {
		reverse_proxy auth-service:3001
	}

	# NO general `/v1/*` route — DELIBERATE. Only /v1/portal/* above is proxied;
	# a stray /v1/<other> request falls through to the SPA fallback (index.html),
	# never to tenant data.

	# Everything else: the portal-web static SPA baked into this image at
	# /srv/portal. Same SPA-fallback shape as the other consoles.
	handle {
		root * /srv/portal
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd
}
