# Aramo — Single-Box PROD env contract (example).
#
# The full env surface the prod stack (docker-compose.prod.yml) reads. Copy to a
# real `.env` on the box (or locally for provability) and fill in real values.
# NEVER commit a real `.env` or a real secret; no secret is ever baked into an
# image layer.
#
# How it's consumed (the proven multi-line-PEM-safe pattern from D1):
#   set -a && source .env && set +a
#   docker compose --env-file /dev/null -f docker-compose.prod.yml up -d
# Bare-name `environment:` entries in the compose pass through from this sourced
# shell env verbatim (multi-line PEM keys survive — compose never parses them).
#
# Values here are PLACEHOLDERS. This documents the prod surface only; the dev
# contract stays in .env.example.

# ── Front-door / Caddy (TLS + domain parameterization) ──────────────────────
# Unset → the Caddyfile defaults (localhost + `tls internal`, the local CA) so
# the stack runs+tests on a laptop with NO public domain. On the box, set:
#   CADDY_SITE_ADDRESS=astre.aramo.ai
#   CADDY_TLS=admin@aramo.ai      # an ACME email → real Let's Encrypt cert
CADDY_SITE_ADDRESS=localhost
CADDY_TLS=internal

# ── Backend images (D1 / ECR) ───────────────────────────────────────────────
# The D1 images are referenced, not rebuilt. Local default = the local D1 tags;
# on the box point these at the ECR tags (D2). Optional (defaults applied).
# ARAMO_API_IMAGE=aramo/api:local
# ARAMO_AUTH_IMAGE=aramo/auth-service:local

# ── Runtime ─────────────────────────────────────────────────────────────────
# NODE_ENV is forced to `production` by the compose for api + auth-service.
# ARAMO_ENV selects per-env resources (incl. the Secrets-Manager secret id for
# the Anthropic key — see below). Prod value:
ARAMO_ENV=prod

# ── Database (Postgres) ─────────────────────────────────────────────────────
# These configure the in-stack postgres service AND are interpolated into the
# api/auth DATABASE_URL (host pinned to the `postgres` service name) — they
# cannot drift. Use a real password on the box.
POSTGRES_USER=aramo
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=aramo
# Postgres + Redis are container-internal; their URLs are PINNED to the compose
# service names inside docker-compose.prod.yml — do NOT set DATABASE_URL /
# REDIS_URL here (the .env localhost values are unreachable in-container).

# ── Auth / Cognito (reused pool us-east-1_4fKlnGfaW) ────────────────────────
# auth-service reads these; api reads the subset it needs (audience, public key,
# tenant pool id, cognito endpoint).
AUTH_AUDIENCE=
AUTH_COGNITO_DOMAIN=
AUTH_COGNITO_CLIENT_ID=
AUTH_COGNITO_ISSUER=
AUTH_COGNITO_TENANT_USER_POOL_ID=
AUTH_COGNITO_ENDPOINT=
# The hosted-UI callback — must be a registered callback URL on the app client.
# Box: https://astre.aramo.ai/auth/recruiter/callback
AUTH_COGNITO_REDIRECT_URI=
# Where /auth/:consumer/callback 302s after a successful login (box: the app
# origin https://astre.aramo.ai).
AUTH_POST_LOGIN_REDIRECT=
# The registered post-logout return URL (box: https://astre.aramo.ai/login).
AUTH_COGNITO_SIGNOUT_REDIRECT=
# Federated-IdP allow-list (comma-separated; e.g. Google,Microsoft).
AUTH_TRUSTED_IDP_NAMES=
AUTH_REFRESH_GRACE_SECONDS=60
# Leave UNSET/false in prod: cookies are Secure under Caddy HTTPS. (Forced
# Secure anyway when NODE_ENV=production, which the compose sets.)
AUTH_ALLOW_INSECURE_COOKIES=false

# ── JWT session signing (asymmetric PEM keys) ───────────────────────────────
# Multi-line PEM. Passed through verbatim via the sourced-shell pattern above.
# auth-service signs (private+public); api verifies (public only).
AUTH_PRIVATE_KEY=
AUTH_PUBLIC_KEY=
AUTH_PKCE_STATE_KEY=

# ── AWS / S3 (résumé + attachment storage) ──────────────────────────────────
# These creds ALSO authorize the Anthropic-key fetch from Secrets Manager (see
# below). On the box the D2 task role supplies creds; locally set them here.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_RESUME_BUCKET=

# ── Email / SES (transactional mailer — Email-S1) ───────────────────────────
# MAILER_PROVIDER selects the mailer adapter. REQUIRED (no default → an unset
# value fails LOUD at module binding, so email can't be silently dropped):
#   ses  — real SES send (prod). Requires SES_FROM_ADDRESS + the api principal's
#          ses:SendEmail grant (infrastructure-lightsail/ses-mailer-iam.json).
#   stub — log-only, no network (local/dev). Logs at WARN that nothing was sent.
# SES_FROM_ADDRESS is the fixed sender (callers never choose). The adapter
# passes it verbatim to SES FromEmailAddress, so it accepts RFC-5322
# display-name format ("Aramo Support <support@aramo.ai>"). The IAM
# ses:FromAddress condition keys on the ADDRESS part only (support@aramo.ai),
# so the display name does not affect the grant. Reuses AWS_REGION above
# (us-east-1) + the same default-chain creds as the S3 résumé adapter.
# NOTE: double-quote it — the box sources this via `set -a && source .env`,
# so the spaces + angle brackets must be quoted or shell parsing breaks.
MAILER_PROVIDER=ses
SES_FROM_ADDRESS="Aramo Support <support@aramo.ai>"

# ── Anthropic API key — NOT an env var (flag) ───────────────────────────────
# The codebase does NOT read ANTHROPIC_API_KEY. The key is fetched at runtime
# from AWS Secrets Manager at secret id `aramo/${ARAMO_ENV}/anthropic-api-key`
# (libs/ai-draft SecretCacheService), authorized by the AWS_* creds above. So
# the "Anthropic key" enters via Secrets Manager + ARAMO_ENV, not the env.

# ── Address autocomplete ────────────────────────────────────────────────────
ADDRESS_AUTOCOMPLETE_ENABLED=true
ADDRESS_AUTOCOMPLETE_PROVIDER=google
GOOGLE_PLACES_API_KEY=

# ── Import engine ───────────────────────────────────────────────────────────
IMPORT_FAILURE_THRESHOLD_PCT=20
