# Aramo — Single-Box PROD env contract (example).
#
# The full env surface the prod stack (docker-compose.prod.yml) reads. Copy to a
# real `.env` on the box (or locally for provability) and fill in real values.
# NEVER commit a real `.env` or a real secret; no secret is ever baked into an
# image layer.
#
# How it's consumed (the proven multi-line-PEM-safe pattern from D1):
#   set -a && source .env && set +a
#   docker compose --env-file /dev/null -f docker-compose.prod.yml up -d
# Bare-name `environment:` entries in the compose pass through from this sourced
# shell env verbatim (multi-line PEM keys survive — compose never parses them).
#
# Values here are PLACEHOLDERS. This documents the prod surface only; the dev
# contract stays in .env.example.

# ── Front-door / Caddy (TLS + domain parameterization) ──────────────────────
# Unset → the Caddyfile defaults (localhost + `tls internal`, the local CA, NO
# on-demand) so the stack runs+tests on a laptop with NO public domain. On the
# box, Subdomain-Identity Directive A serves EVERY tenant subdomain off one
# wildcard host with tenant-validated on-demand TLS — set all three:
#   CADDY_SITE_ADDRESS=*.aramo.ai   # wildcard host (subsumes astre.aramo.ai);
#                                   # any <slug>.aramo.ai is served, no per-tenant
#                                   # block. Onboarding = a Tenant row, not infra.
#   CADDY_TLS=admin@aramo.ai        # an ACME email → real Let's Encrypt certs
#   CADDY_TLS_ONDEMAND=on_demand    # mint a per-host cert just-in-time, gated by
#                                   # the ask-endpoint (only real active tenant
#                                   # slugs get certs). Keeps HTTP-01 — no DNS-01,
#                                   # no Route53 plugin/creds on Caddy.
# CADDY_ASK_URL is optional (defaults to the compose-internal api ask-endpoint).
CADDY_SITE_ADDRESS=localhost
CADDY_TLS=internal
CADDY_TLS_ONDEMAND=
# Inc-3 PR-3.3 — the platform console host (admin.aramo.ai). A DEDICATED site
# block with ORDINARY ACME (no on_demand, ask-endpoint never involved — R14);
# reuses CADDY_TLS above. On the box: admin.aramo.ai (the existing *.aramo.ai
# wildcard DNS record already resolves it). Local default = admin.localhost.
CADDY_ADMIN_ADDRESS=admin.aramo.ai
# D-CADDY-WILDCARD-SKIP-1 — the admin block's `tls` arg. On the box:
# force_automate — adds admin.aramo.ai to Caddy's `automate` loader, bypassing
# the >=2.10 wildcard-coverage issuance skip (*.aramo.ai is in the managed set
# but never obtained: on_demand + no DNS-01 module), so the platform console
# gets an ordinary HTTP-01 cert. R14 unchanged (no on_demand, ask-endpoint
# uninvolved). The ACME account email comes from CADDY_TLS via the global
# options block. Local default: internal (Caddy's local CA). MUST also be in the
# caddy service passthrough (docker-compose.prod.yml) or the fix is inert.
CADDY_ADMIN_TLS=force_automate
# Portal P1 PR-3 — the talent-facing portal host (candidate.aramo.ai). A
# DEDICATED site block with ORDINARY ACME (same R14 posture as admin above);
# reuses CADDY_TLS. On the box: candidate.aramo.ai (a DNS record — A/CNAME in
# Route53 — is required before the host serves). Local default = portal.localhost
# (internal name per Amendment v1.1). Pairs with AUTH_PORTAL_HOSTS + PORTAL_LOGIN_BASE_URL.
CADDY_PORTAL_ADDRESS=candidate.aramo.ai

# ── Front-door / nginx (Front-Door Migration PR-2 — built INERT) ─────────────
# The nginx + certbot services are profile-gated (profiles: ["frontdoor"]) and
# do NOT start on a plain `docker compose up -d` — caddy keeps 80/443 until the
# PR-3 cutover flip. These four vars parameterize nginx's server_names + cert dir;
# unset → the template's LOCAL defaults (localhost / admin.localhost /
# portal.localhost / /etc/letsencrypt/live/aramo.ai). On the box set the wildcard
# + subdomain hosts (mirrors the CADDY_* values above). Bare-name passthrough —
# a var absent from the compose `environment:` reverts to local (D-AUTH-PLATFORM-
# HOSTS-1 defect class).
NGINX_TENANT_SERVER_NAME=*.aramo.ai
NGINX_ADMIN_SERVER_NAME=admin.aramo.ai
NGINX_PORTAL_SERVER_NAME=candidate.aramo.ai
NGINX_CERT_DIR=/etc/letsencrypt/live/aramo.ai

# ── Backend images (D1 / ECR) ───────────────────────────────────────────────
# The D1 images are referenced, not rebuilt. Local default = the local D1 tags;
# on the box point these at the ECR tags (D2). Optional (defaults applied).
# ARAMO_API_IMAGE=aramo/api:local
# ARAMO_AUTH_IMAGE=aramo/auth-service:local
# Inc-3 PR-3.3 — the platform-admin image (built + published from main like the
# others). Local default = the local build tag; on the box point at the GHCR tag.
# ARAMO_PLATFORM_ADMIN_IMAGE=aramo/platform-admin:local

# ── Runtime ─────────────────────────────────────────────────────────────────
# NODE_ENV is forced to `production` by the compose for api + auth-service.
# ARAMO_ENV selects per-env resources (incl. the Secrets-Manager secret id for
# the Anthropic key — see below). Prod value:
ARAMO_ENV=prod

# ── Database (Postgres) ─────────────────────────────────────────────────────
# These configure the in-stack postgres service AND are interpolated into the
# api/auth DATABASE_URL (host pinned to the `postgres` service name) — they
# cannot drift. Use a real password on the box.
POSTGRES_USER=aramo
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=aramo
# Postgres + Redis are container-internal; their URLs are PINNED to the compose
# service names inside docker-compose.prod.yml — do NOT set DATABASE_URL /
# REDIS_URL here (the .env localhost values are unreachable in-container).

# ── Auth / Cognito (reused pool us-east-1_4fKlnGfaW) ────────────────────────
# auth-service reads these; api reads the subset it needs (audience, public key,
# tenant pool id, cognito endpoint); platform-admin reads audience + public key
# + BOTH pool ids (tenant-owner invites → tenant pool; platform-admin invites →
# platform pool) + cognito endpoint + AWS creds.
AUTH_AUDIENCE=
AUTH_COGNITO_DOMAIN=
AUTH_COGNITO_CLIENT_ID=
AUTH_COGNITO_ISSUER=
AUTH_COGNITO_TENANT_USER_POOL_ID=
# Inc-3 PR-3.3 — the PLATFORM Cognito user pool (platform-admin invitations mint
# platform operators here; distinct from the tenant pool above). Required by
# platform-admin only.
AUTH_COGNITO_PLATFORM_USER_POOL_ID=
AUTH_COGNITO_ENDPOINT=
# PR-3.1 (host-derived base): the callback/post-login/signout bases now DERIVE
# from the request's VALIDATED host FIRST (tenant host via findActiveBySlug,
# platform host via AUTH_PLATFORM_HOSTS, or localhost under dev posture), so
# astre.aramo.ai + admin.aramo.ai + both localhost consoles work concurrently
# with the envs below UNSET. The envs remain the escape hatch for unvalidated
# hosts (and existing single-console prod). A raw Host never reaches a redirect.
#
# AUTH_PLATFORM_HOSTS — comma-separated exact platform console hosts (lowercased,
# port-stripped) whose login derives an https base. Prod default: admin.aramo.ai.
AUTH_PLATFORM_HOSTS=admin.aramo.ai
# Portal P1 — AUTH_PORTAL_HOSTS: the portal host class (sibling to platform),
# the exact host(s) whose passwordless login derives an https base. On the box:
# candidate.aramo.ai. PORTAL_LOGIN_BASE_URL is the magic-link base (the portal
# origin) used when a request host is not a validated portal host.
AUTH_PORTAL_HOSTS=candidate.aramo.ai
PORTAL_LOGIN_BASE_URL=https://candidate.aramo.ai
# AUTH_POST_LOGIN_PATH / AUTH_SIGNOUT_PATH — the path appended to a DERIVED base
# for the post-login / post-logout landing (default '/'). Used only when a host
# validates; unvalidated hosts fall back to the full-URL envs below.
AUTH_POST_LOGIN_PATH=/
AUTH_SIGNOUT_PATH=/
# The public origin the browser reaches the app on. Fallback for UNVALIDATED
# hosts (host-derivation wins when the host validates). auth-service derives the
# hosted-UI callback per consumer as ${AUTH_PUBLIC_BASE_URL}/auth/<consumer>/callback
# at authorize + token-exchange (Amendment v1.2 Workstream D). Each derived URL
# must be a registered callback on the app client. The recruiter derivation
# matches the currently-registered prod URL (https://astre.aramo.ai/auth/recruiter/callback).
# Box: https://astre.aramo.ai
AUTH_PUBLIC_BASE_URL=
# DEPRECATED (Amendment v1.2): the single-valued full callback URL. Fallback only
# — if AUTH_PUBLIC_BASE_URL is unset, its ORIGIN is used as the base.
# Box (legacy): https://astre.aramo.ai/auth/recruiter/callback
AUTH_COGNITO_REDIRECT_URI=
# Where /auth/:consumer/callback 302s after a successful login for an UNVALIDATED
# host (a validated host derives ${base}${AUTH_POST_LOGIN_PATH}). Box: the app
# origin https://astre.aramo.ai.
AUTH_POST_LOGIN_REDIRECT=
# The registered post-logout return URL for an UNVALIDATED host (box:
# https://astre.aramo.ai/login).
AUTH_COGNITO_SIGNOUT_REDIRECT=
# Federated-IdP allow-list (comma-separated; e.g. Google,Microsoft).
AUTH_TRUSTED_IDP_NAMES=
AUTH_REFRESH_GRACE_SECONDS=60
# Leave UNSET/false in prod: cookies are Secure under Caddy HTTPS. (Forced
# Secure anyway when NODE_ENV=production, which the compose sets.)
AUTH_ALLOW_INSECURE_COOKIES=false

# ── JWT session signing (asymmetric PEM keys) ───────────────────────────────
# Multi-line PEM. Passed through verbatim via the sourced-shell pattern above.
# auth-service signs (private+public); api verifies (public only).
AUTH_PRIVATE_KEY=
AUTH_PUBLIC_KEY=
AUTH_PKCE_STATE_KEY=

# ── AWS / S3 (résumé + attachment storage) ──────────────────────────────────
# These creds ALSO authorize the Anthropic-key fetch from Secrets Manager (see
# below). On the box the D2 task role supplies creds; locally set them here.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_RESUME_BUCKET=

# ── certbot DNS-01 credentials (Front-Door PR-2 / PR-0 Ruling 7) ─────────────
# The DEDICATED certbot IAM principal from PR-0 (aramo-certbot-dns) — kept
# SEPARATE from the box-wide AWS_* app creds above. Generated out-of-band per
# doc/runbooks/frontdoor-pr0-apply.md and staged into the box .env. The certbot
# service maps these onto the AWS_ACCESS_KEY_ID/SECRET the dns-route53 plugin
# reads (see docker-compose.prod.yml). Least-privilege: TXT / _acme-challenge.
# aramo.ai only. AWS_REGION above is reused.
CERTBOT_AWS_ACCESS_KEY_ID=
CERTBOT_AWS_SECRET_ACCESS_KEY=

# ── Email / SES (transactional mailer — Email-S1) ───────────────────────────
# MAILER_PROVIDER selects the mailer adapter. REQUIRED (no default → an unset
# value fails LOUD at module binding, so email can't be silently dropped):
#   ses  — real SES send (prod). Requires SES_FROM_ADDRESS + the api principal's
#          ses:SendEmail grant (infrastructure-lightsail/ses-mailer-iam.json).
#   stub — log-only, no network (local/dev). Logs at WARN that nothing was sent.
# SES_FROM_ADDRESS is the fixed sender (callers never choose). The adapter
# passes it verbatim to SES FromEmailAddress, so it accepts RFC-5322
# display-name format ("Aramo Support <support@aramo.ai>"). The IAM
# ses:FromAddress condition keys on the ADDRESS part only (support@aramo.ai),
# so the display name does not affect the grant. Reuses AWS_REGION above
# (us-east-1) + the same default-chain creds as the S3 résumé adapter.
# NOTE: double-quote it — the box sources this via `set -a && source .env`,
# so the spaces + angle brackets must be quoted or shell parsing breaks.
MAILER_PROVIDER=ses
SES_FROM_ADDRESS="Aramo Support <support@aramo.ai>"

# ── DNS resolver for domain verification (Domain-Enforcement P2b) ───────────
# Selects the DNS resolver the domain-ownership (DNS-TXT) check uses. REQUIRED
# (no default → loadDnsConfig fails LOUD at module binding if unset, so the api
# can't silently "verify" nothing):
#   node — real DNS lookups via Node's built-in dns (prod).
#   stub — canned records, no network (local/dev/test).
# (DNS_RECORD_PREFIX / DNS_VALUE_PREFIX are optional overrides with sane
# defaults — '_aramo-challenge' / 'aramo-domain-verification=' — set only to
# change the challenge record name/value prefix.)
DNS_PROVIDER=node

# ── Invite links (Invite-S2 / Pattern-2 invite flow) ────────────────────────
# The invite email's accept link points at the FE acceptance page (which POSTs
# the token to the public POST /v1/invitations/accept endpoint); the
# acceptance-confirmation email points at the sign-in page. Both fall back to a
# localhost default if unset (dev), so set the box origin in prod.
#   Box: INVITE_ACCEPT_URL=https://astre.aramo.ai/invitations/accept
#        INVITE_SIGNIN_URL=https://astre.aramo.ai/login
INVITE_ACCEPT_URL=https://astre.aramo.ai/invitations/accept
INVITE_SIGNIN_URL=https://astre.aramo.ai/login

# ── Anthropic API key — NOT an env var (flag) ───────────────────────────────
# The codebase does NOT read ANTHROPIC_API_KEY. The key is fetched at runtime
# from AWS Secrets Manager at secret id `aramo/${ARAMO_ENV}/anthropic-api-key`
# (libs/ai-draft SecretCacheService), authorized by the AWS_* creds above. So
# the "Anthropic key" enters via Secrets Manager + ARAMO_ENV, not the env.

# ── Address autocomplete ────────────────────────────────────────────────────
ADDRESS_AUTOCOMPLETE_ENABLED=true
ADDRESS_AUTOCOMPLETE_PROVIDER=google
GOOGLE_PLACES_API_KEY=

# ── Import engine ───────────────────────────────────────────────────────────
IMPORT_FAILURE_THRESHOLD_PCT=20

# ── Identity index admission policy (TR-2b B1 / Ruling D15) ──────────────────
# Platform-global switch gating the cross-tenant identity_index aperture-1
# fingerprint mint. Closed vocabulary: PORTABLE_ONLY | ALL_ARRIVALS; frozen
# behind a switch per Decision 15 (ALL_ARRIVALS enters pre-switch history ONLY
# via the audited backfill command, never silent retro-ingestion). REQUIRED —
# api-only; loadIdentityAdmissionPolicy fails LOUD on the canonicalization mint
# path if unset/unknown. Launch value: PORTABLE_ONLY.
ARAMO_IDENTITY_ADMISSION_POLICY=PORTABLE_ONLY

# Indeed Apply inbound webhook secret (SRC-1 PR-2 / R9). The partner-provisioned
# Indeed Apply "api Secret" — the HMAC key the POST /v1/webhooks/indeed/apply
# endpoint uses to verify the X-Indeed-Signature header. api-only. UNSET →
# the endpoint refuses ALL traffic (503, dark by construction, R5); the webhook
# ships dark until the Indeed partnership is executed (SRC-2 turns it on). Set
# to the real secret only when a partner credential exists. Must also appear as
# a bare-name passthrough in docker-compose.prod.yml api `environment:` — a var
# read by container code but absent from the passthrough never reaches the
# container (the D-AUTH-PLATFORM-HOSTS-1 defect class).
ARAMO_INDEED_APPLY_WEBHOOK_SECRET=

# SRC-2 PR-3 (R7) — Indeed Job Sync partner OAuth app credentials (platform-level,
# R5: ONE app for all tenants; NEVER per-tenant config). The freshness sweep is
# fail-closed: unset → the connector is disabled and the sweep skips every tick
# (one log line, no crash-loop). Set only when a partner credential exists. Must
# also appear as bare-name passthroughs in docker-compose.prod.yml api
# `environment:` (the D-AUTH-PLATFORM-HOSTS-1 defect class). api-only.
ARAMO_INDEED_CLIENT_ID=
ARAMO_INDEED_CLIENT_SECRET=
# OAuth scope (DEV-C), env-overridable. Default (employer_access) is applied in
# code when unset — set only if certification requires a different scope.
ARAMO_INDEED_OAUTH_SCOPE=
# GraphQL base URL (DEV-C), env-overridable. Default (https://apis.indeed.com/graphql)
# is applied in code when unset — set to the simulated GraphQL environment during
# certification without a code change.
ARAMO_INDEED_GRAPHQL_BASE=
