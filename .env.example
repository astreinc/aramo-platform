# Aramo platform — environment contract (example).
#
# Copy to `.env` and fill in real values for local development. NEVER commit a
# real `.env` or a real secret. This file documents the env keys the services
# read via process.env (the established config pattern — there is no
# @nestjs/config layer). Values here are PLACEHOLDERS only.
#
# Introduced by Address-Autocomplete v1.0 (which added the first three keys
# below); the remaining keys are enumerated from the existing services.

# --- Address autocomplete (Address-Autocomplete v1.0) -----------------------
# Backend-proxied company address typeahead. The key is read server-side only
# and is NEVER sent to the browser.
#   ADDRESS_AUTOCOMPLETE_ENABLED  — feature gate; the routes return empty
#     results unless this is exactly "true". Ships dark by default.
#   ADDRESS_AUTOCOMPLETE_PROVIDER — "google" (live, default) or "mock"
#     (canned; used by tests/CI so no billing key is required there).
#   GOOGLE_PLACES_API_KEY         — required when PROVIDER=google AND ENABLED.
ADDRESS_AUTOCOMPLETE_PROVIDER=google
ADDRESS_AUTOCOMPLETE_ENABLED=true
GOOGLE_PLACES_API_KEY=your_places_api_key_here

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
ARAMO_ENV=local
PORT=3000

# --- Database (Postgres) ----------------------------------------------------
DATABASE_URL=postgresql://aramo:aramo@localhost:5432/aramo?schema=public

# --- Redis (BullMQ queues) --------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth / Cognito ---------------------------------------------------------
AUTH_COGNITO_DOMAIN=
AUTH_COGNITO_ISSUER=
AUTH_COGNITO_CLIENT_ID=
# PR-3.1 (host-derived base): with AUTH_ALLOW_INSECURE_COOKIES=true (below), the
# callback/post-login/signout bases DERIVE from the request host — so recruiter on
# localhost:4201 AND platform on localhost:4202 both round-trip in ONE stack with
# AUTH_PUBLIC_BASE_URL UNSET (comment the line below). The env-flip is dead; the
# env remains a fallback for unvalidated hosts. (prod hosts: AUTH_PLATFORM_HOSTS
# in .env.prod.example.)
#
# The public origin the browser reaches the app on. auth-service derives the
# hosted-UI callback per consumer as ${AUTH_PUBLIC_BASE_URL}/auth/<consumer>/callback
# at BOTH authorize and token-exchange (Amendment v1.2 Workstream D). Local:
# http://localhost:4201 (leave set for a single console; UNSET to derive both).
AUTH_PUBLIC_BASE_URL=http://localhost:4201
# DEPRECATED (Amendment v1.2): the single-valued full callback URL. Retained only
# as a fallback — if AUTH_PUBLIC_BASE_URL is unset, its ORIGIN is used as the base.
# It hardwired one consumer at a time; prefer AUTH_PUBLIC_BASE_URL.
AUTH_COGNITO_REDIRECT_URI=
AUTH_COGNITO_ENDPOINT=
AUTH_COGNITO_TENANT_USER_POOL_ID=
AUTH_COGNITO_PLATFORM_USER_POOL_ID=
AUTH_AUDIENCE=aramo-local
# Where /auth/:consumer/callback 302s after a successful login. LOCAL = the FE
# origin (the vite dev server on :4201). Throws if unset — setting it locally is
# what makes auth.integration test-39 pass off-CI (see doc/runbooks/local-run.md).
AUTH_POST_LOGIN_REDIRECT=http://localhost:4201
# §5 Auth-Hardening D3: the REGISTERED post-logout return URL. Must match an
# "Allowed sign-out URL" on the Cognito app client (per-env: local + staging +
# prod). Config, never user input (open-redirect guard); throws if unset.
# LOCAL = the FE login page on :4201.
AUTH_COGNITO_SIGNOUT_REDIRECT=http://localhost:4201/login
AUTH_PKCE_STATE_KEY=
AUTH_REFRESH_GRACE_SECONDS=60
# Local-only convenience: allow non-Secure cookies over http://localhost.
# Safe to leave true for local — shouldSetSecure() still forces Secure when
# NODE_ENV=production regardless of this flag.
AUTH_ALLOW_INSECURE_COOKIES=true
# Asymmetric session-token signing keys (PEM). Generate locally; never commit.
AUTH_PRIVATE_KEY=
AUTH_PUBLIC_KEY=

# --- AWS / S3 (résumé + attachment storage) ---------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_RESUME_BUCKET=

# --- Import engine ----------------------------------------------------------
# Abort an import batch when the row-failure rate exceeds this percentage.
IMPORT_FAILURE_THRESHOLD_PCT=20

# --- Identity fingerprint pepper (Step 4b / ADR-0016) -----------------------
# The platform secret keying the cross-tenant email fingerprint (HMAC-SHA256).
# Held SEPARATE from the database so an identity_index-only breach yields
# pepperless (useless) fingerprints. REQUIRED for the API: canonicalization
# fails LOUD (loadIdentityPepper throws) rather than mis-resolving with an
# unkeyed fingerprint. Generate a long random value; NEVER commit a real one.
# Rotating it re-keys all FUTURE fingerprints (existing clusters keep matching
# only while the pepper is unchanged). Migrate to KMS/HSM later.
# 3-place deploy wiring: this .env on the box + the committed
# docker-compose.prod.yml passthrough + a container recreate to pick it up.
ARAMO_IDENTITY_PEPPER=replace_with_a_long_random_secret

# --- Test harness -----------------------------------------------------------
# Set to "1" to run the integration specs (they need Postgres/Redis testcontainers).
ARAMO_RUN_INTEGRATION=

# ── ats-web live e2e (apps/ats-web/e2e) ──
# Dedicated least-privilege TEST recruiter Cognito user (recruiter scopes only).
# Provide via env/secret at run time — NEVER commit real values.
RC_E2E_USERNAME=
RC_E2E_PASSWORD=
# Optional base32 TOTP seed (omit if MFA is disabled for the test user).
RC_E2E_TOTP_SECRET=
# Optional overrides.
RC_E2E_BASE_URL=http://localhost:4201
RC_E2E_CHROMIUM=
