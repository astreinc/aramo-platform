# Aramo M4 PR-8 — example variables for prod environment
# Copy to terraform.tfvars (gitignored) and populate before terraform init.

aws_region  = "us-east-1"
environment = "prod"

# M4 PR-9 — CloudWatch log retention per ADR-0013 Decision 4.
api_log_retention_days  = 90
auth_log_retention_days = 90
