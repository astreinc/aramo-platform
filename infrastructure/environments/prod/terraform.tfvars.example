# Aramo M4 PR-8 — example variables for prod environment
# Copy to terraform.tfvars (gitignored) and populate before terraform init.

aws_region  = "us-east-1"
environment = "prod"

# M4 PR-9 — CloudWatch log retention per ADR-0013 Decision 4.
api_log_retention_days  = 90
auth_log_retention_days = 90

# A8-3a — résumé bucket. Set to the prod app origin(s); NEVER "*".
resume_bucket_cors_allowed_origins    = ["https://aramo.app"]
resume_bucket_retention_days_default  = 365
resume_bucket_retention_days_extended = 2555

# ---------------------------------------------------------------------------
# Step-4 Directive 2 — compute / run layer.
# Sizing defaults are modest (compute-variables.tf); bump for prod here.
# ---------------------------------------------------------------------------
api_cpu         = 1024
api_memory      = 2048
auth_cpu        = 512
auth_memory     = 1024
redis_node_type = "cache.t4g.small"
# api_image_tag  = "<release-git-sha>"   # pin to a digest/SHA for prod
# auth_image_tag = "<release-git-sha>"

