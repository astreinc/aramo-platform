# Aramo M4 PR-8 — example variables for staging environment
# Copy to terraform.tfvars (gitignored) and populate before terraform init.

aws_region  = "us-east-1"
environment = "staging"

# M4 PR-9 — CloudWatch log retention per ADR-0013 Decision 4.
api_log_retention_days  = 30
auth_log_retention_days = 30

# A8-3a — résumé bucket. Set to the staging app origin(s); NEVER "*".
resume_bucket_cors_allowed_origins    = ["https://staging.aramo.app"]
resume_bucket_retention_days_default  = 365
resume_bucket_retention_days_extended = 2555
