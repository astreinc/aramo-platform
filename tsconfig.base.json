{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@aramo/activity": ["libs/activity/src/index.ts"],
      "@aramo/api": ["apps/api/src/app.module.ts"],
      "@aramo/attachment": ["libs/attachment/src/index.ts"],
      "@aramo/audit": ["libs/audit/src/index.ts"],
      "@aramo/ai-draft": ["libs/ai-draft/src/index.ts"],
      "@aramo/auth": ["libs/auth/src/index.ts"],
      "@aramo/auth-service": ["apps/auth-service/src/app/auth/auth.module.ts"],
      "@aramo/auth-storage": ["libs/auth-storage/src/index.ts"],
      "@aramo/authorization": ["libs/authorization/src/index.ts"],
      "@aramo/calendar": ["libs/calendar/src/index.ts"],
      "@aramo/canonicalization": ["libs/canonicalization/src/index.ts"],
      "@aramo/common": ["libs/common/src/index.ts"],
      "@aramo/company": ["libs/company/src/index.ts"],
      "@aramo/consent": ["libs/consent/src/index.ts"],
      "@aramo/contact": ["libs/contact/src/index.ts"],
      "@aramo/engagement": ["libs/engagement/src/index.ts"],
      "@aramo/entitlement": ["libs/entitlement/src/index.ts"],
      "@aramo/entrustability": ["libs/entrustability/src/index.ts"],
      "@aramo/events": ["libs/events/src/index.ts"],
      "@aramo/export": ["libs/export/src/index.ts"],
      "@aramo/evidence": ["libs/evidence/src/index.ts"],
      "@aramo/fe-foundation": ["libs/fe-foundation/src/index.ts"],
      "@aramo/field-masking": ["libs/field-masking/src/index.ts"],
      "@aramo/examination": ["libs/examination/src/index.ts"],
      "@aramo/identity": ["libs/identity/src/index.ts"],
      "@aramo/import": ["libs/import/src/index.ts"],
      "@aramo/ingestion": ["libs/ingestion/src/index.ts"],
      "@aramo/job-domain": ["libs/job-domain/src/index.ts"],
      "@aramo/matching": ["libs/matching/src/index.ts"],
      "@aramo/metering": ["libs/metering/src/index.ts"],
      "@aramo/object-storage": ["libs/object-storage/src/index.ts"],
      "@aramo/outbox-publisher": ["libs/outbox-publisher/src/index.ts"],
      "@aramo/pipeline": ["libs/pipeline/src/index.ts"],
      "@aramo/portal": ["libs/portal/src/index.ts"],
      "@aramo/reporting": ["libs/reporting/src/index.ts"],
      "@aramo/requisition": ["libs/requisition/src/index.ts"],
      "@aramo/resume-parse": ["libs/resume-parse/src/index.ts"],
      "@aramo/saved-list": ["libs/saved-list/src/index.ts"],
      "@aramo/settings": ["libs/settings/src/index.ts"],
      "@aramo/skills-taxonomy": ["libs/skills-taxonomy/src/index.ts"],
      "@aramo/submittal": ["libs/submittal/src/index.ts"],
      "@aramo/talent": ["libs/talent/src/index.ts"],
      "@aramo/talent-evidence": ["libs/talent-evidence/src/index.ts"],
      "@aramo/talent-record": ["libs/talent-record/src/index.ts"],
      "@aramo/task": ["libs/task/src/index.ts"],
      "@aramo/visibility": ["libs/visibility/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", "build", "**/prisma/generated"]
}
