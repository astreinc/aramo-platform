{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/libs/common",
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "tsBuildInfoFile": "../../dist/libs/common/.tsbuildinfo",
    "types": ["node"],
    "paths": {}
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/tests/**/*", "**/*.spec.ts"]
}
