// Per-module Prisma schema for the `submittal` module — M4 PR-3
// (TalentSubmittalRecord entity foundation + submittal-create endpoint).
//
// Schema: `engagement` per Architecture v2.0/v2.1 §7.1 ten-schema list.
// First model in the engagement schema; subsequent M5 work (engagement
// state machine, TalentEngagementEvent) lands additional models here.
//
// Cross-schema references (Architecture §7.3 — UUID-only, no FK):
//   - evidence_package_id → evidence schema (PR-1's TalentJobEvidencePackage)
//   - pinned_examination_id → examination schema (M3 PR-1's TalentJobExamination)
//
// Per Group 2 §2.6 architecture split: TalentJobEvidencePackage is the
// immutable deliverable; TalentSubmittalRecord is the workflow entity
// that references it. Two distinct entities; distinct lifecycles. PR-3
// is the first PR to introduce the workflow entity.
//
// Per Group 2 §2.3b Loop 5 the full state machine is 5-value
// (created/handoff_draft/ready_for_review/submitted_to_ats/confirmed).
// M5 PR-8b2 closes F37 (rename + cutover phase replacing M4's 2-value
// subset draft/submitted with the canonical 5-state chain).
//
// Immutability: column-scoped — `state` may transition along the
// canonical chain and `confirmed_at` populates at the
// ready_for_review → submitted_to_ats transition (preserving M4's
// confirmed_at column semantic; the M4 "confirmed" event renames to
// canonical "submitted to ATS"). Every other column is immutable
// post-create. Enforced by the BEFORE UPDATE trigger rewritten at
// PR-8b2 to encode the canonical 5-state matrix.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["engagement"]
}

// SubmittalState — canonical 5-state machine per Group 2 §2.3b Loop 5
// (+ sibling lifecycle-exit state `revoked`). F37 closes at M5 PR-8b2
// via the rename + cutover phase that replaces M4's 2-value subset
// (draft, submitted) with the canonical 5-state chain and ADDs the
// 3 intermediate states (handoff_draft, ready_for_review, confirmed).
//
// State chain (mainline; 4 transitions):
//   created -> handoff_draft -> ready_for_review -> submitted_to_ats
//   -> confirmed
//
// Sibling lifecycle-exit (revoked; Q3 Lead-Rulings Brief v1.0-LOCKED):
// revocable from `created`, `handoff_draft`, `ready_for_review`,
// `submitted_to_ats`. NOT revocable from `confirmed` (terminal state
// per Ruling 5 — ATS confirmation closes the workflow lifecycle).
//
// Rename semantics (Q3 Lead-Rulings Brief):
//   - M4 'draft' renames to 'created' (lifecycle start state).
//   - M4 'submitted' renames to 'submitted_to_ats' (explicit canonical
//     name; M4's `submitted` meant ATS-submitted).
//   - 'revoked' UNCHANGED (sibling lifecycle-exit).
//
// The column-scoped immutability trigger
// (engagement.reject_submittal_record_update) encodes the canonical
// 5-state matrix (4 mainline + 4 sibling-revoke = 8 legal transitions).
// Terminal states `confirmed` and `revoked` have no outgoing
// transitions. All other transitions raise check_violation.
enum SubmittalState {
  created
  handoff_draft
  ready_for_review
  submitted_to_ats
  confirmed
  revoked

  @@schema("engagement")
}

// M5 PR-8b1 — TalentSubmittalEvent event-log enum. Thin substrate per
// Q6 HYBRID Lead-ruling: one event type (`state_transition`) at PR-8b1;
// richer event types (handoff_drafted, ready_for_review_marked,
// submitted_to_ats_confirmed, confirmed_by_ats) deferred to future
// consumer PRs. Closed-list; future event types added via explicit
// directive amendment. Lives in the engagement PG schema per
// Lead-Q-PR-8b1-A1 (the submittal Prisma module shares the engagement
// schema with TalentSubmittalRecord and TalentJobEngagement).
enum SubmittalEventType {
  state_transition

  @@schema("engagement")
}

// §2.6 — TalentSubmittalRecord (workflow entity referencing the immutable
// TalentJobEvidencePackage). Cross-schema references are UUID-only per
// §7.3.
model TalentSubmittalRecord {
  // Identity.
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @db.Uuid
  talent_id String @db.Uuid
  job_id    String @db.Uuid

  // Cross-schema references (Architecture §7.3 — UUID-only, no FK).
  //
  // evidence_package_id: REQUIRED. References the immutable
  // TalentJobEvidencePackage built at create time (PR-2's
  // EvidenceRepository.buildPackage call). Co-located on submittal so
  // the consuming F34 confirm endpoint can resolve the package without
  // a cross-schema query.
  evidence_package_id String @db.Uuid
  // pinned_examination_id: REQUIRED. References the
  // TalentJobExamination snapshot pinned at draft creation. Co-located
  // on submittal so F34's pin-verification check can fire without
  // re-reading the evidence package.
  pinned_examination_id String @db.Uuid

  // Workflow.
  state      SubmittalState @default(created)
  // UUID of the recruiter actor that initiated the create. Derived
  // from JWT at the controller layer.
  created_by String         @db.Uuid

  // Worth Considering optional payloads — accepted at PR-3, persisted
  // verbatim, NOT enforced. F34 confirm endpoint enforces that Worth
  // Considering tier requires both fields non-empty; missing returns
  // 422 JUSTIFICATION_REQUIRED.
  justification                    String?
  failed_criterion_acknowledgments Json?

  // Lifecycle timestamps. confirmed_at is set at the
  // ready_for_review → submitted_to_ats transition (M5 PR-8b2 §4.3 +
  // Ruling 6 — preserves M4's confirmed_at column semantic; column
  // name unchanged for migration safety + historical-data continuity).
  created_at   DateTime  @default(now()) @db.Timestamptz
  confirmed_at DateTime? @db.Timestamptz

  // M4 PR-7 §4.1 — revoke metadata. Populated atomically with any-state
  // to revoked transition via the submittal-revoke endpoint (per M5
  // PR-8b2 Q3 sibling lifecycle-exit ruling: revocable from `created`,
  // `handoff_draft`, `ready_for_review`, `submitted_to_ats`). The
  // column-scoped trigger requires all three to move from NULL to
  // non-NULL atomically when state moves to revoked; once revoked, no
  // further mutation is permitted on the row.
  revoked_at               DateTime? @db.Timestamptz
  revoked_by               String?   @db.Uuid
  revocation_justification String?

  // Indexes:
  //   - (tenant, talent, job): canonical "submittal for this talent + job" lookup.
  //   - (tenant, evidence_package_id): submittal ↔ evidence package resolution.
  //   - (tenant, state): list submittals by state (e.g., "all drafts").
  //   - (tenant, pinned_examination_id): F34's pin-verification join.
  @@index([tenant_id, talent_id, job_id])
  @@index([tenant_id, evidence_package_id])
  @@index([tenant_id, state])
  @@index([tenant_id, pinned_examination_id])

  // M5 PR-8b1 — back-reference for the TalentSubmittalEvent intra-schema
  // FK. Relation-only field; no column added at the DB layer.
  events TalentSubmittalEvent[]

  @@schema("engagement")
}

// M5 PR-8b1 — TalentSubmittalEvent event-log entity. Per Q6 HYBRID
// Lead-ruling: append-only audit log of submittal workflow events.
// Mirrors libs/engagement TalentEngagementEvent (M5 PR-2) substrate
// shape verbatim — intra-schema FK to TalentSubmittalRecord, JSONB
// payload, absolute-immutability trigger, append-only repository
// surface.
//
// Cardinality: many events per TalentSubmittalRecord. Intra-schema FK
// on submittal_id (both entities live in the `engagement` schema, so
// constraint enforcement is permitted per Architecture §7.3 — UUID-only
// applies to cross-schema refs).
//
// Append-only / absolute-immutability: enforced at the DB layer by a
// BEFORE UPDATE trigger added in the same migration. Precedent: M3 PR-2
// TalentConsentEvent + M4 PR-1 TalentJobEvidencePackage + M5 PR-2
// TalentEngagementEvent absolute-immutability triggers. The repository
// surface exposes appendEvent (create-only) and 4 read methods; no
// update/upsert/delete paths.
//
// Cross-schema references (Architecture §7.3 — UUID-only, no FK):
//   - tenant_id: tenant replication per §7.2.
// Intra-schema references (FK permitted per §7.3):
//   - submittal_id → TalentSubmittalRecord.id (this schema).
//
// event_payload is JSONB per §7.4. The single PR-8b1 event type
// `state_transition` carries `{ from: <SubmittalStateValue>, to:
// <SubmittalStateValue>, ... }` shape (consumer-side typed at PR-8b2+
// wire-in time per Lead-Q-PR-8b1-B1 deferral).
model TalentSubmittalEvent {
  // Identity. UUID v7 generated app-side (PR-2 engagement-event
  // precedent — Postgres 17 has no native uuidv7() function).
  id            String                @id @db.Uuid
  tenant_id     String                @db.Uuid

  // Intra-schema FK to TalentSubmittalRecord.
  submittal_id  String                @db.Uuid
  submittal     TalentSubmittalRecord @relation(fields: [submittal_id], references: [id])

  // Closed-list event type per the SubmittalEventType enum.
  event_type    SubmittalEventType

  // Per-event-type JSONB payload. Shape varies; typed at consumption
  // sites in PR-8b2+ when concrete event-emit paths land.
  event_payload Json

  // Snapshot creation timestamp. No updated_at — entire row is
  // immutable per the absolute-immutability trigger.
  created_at    DateTime              @default(now()) @db.Timestamptz(6)

  // Lookups: (tenant, submittal) primary lookup (events for a given
  // submittal, tenant-scoped); (submittal, created_at) chronological
  // event-log read for a given submittal. Mirrors engagement-event
  // index shape per Lead-Q-PR-8b1-A4.
  @@index([tenant_id, submittal_id])
  @@index([submittal_id, created_at])
  @@schema("engagement")
}
