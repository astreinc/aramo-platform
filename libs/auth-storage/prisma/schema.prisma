// Per-module Prisma schema for the `auth-storage` module.
//
// Per Architecture v2.0 Section 7 (Schema-per-Module data architecture) and
// ADR-0001 Decision 3 (per-module Prisma client generation, isolated output,
// no shared client). Cross-schema references to identity-schema rows are
// UUID-only without FK constraints.
//
// PR-8.0a-Reground introduces this module to persist refresh tokens for
// the Aramo Auth Service. Single model: RefreshToken. Hash-storage at rest
// (SHA-256) per directive §3 Topic 3 D8.b. Rotation chain via
// `replaced_by_id` self-relation; revocation via `revoked_at`.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth_storage"]
}

// Auth-Decoupling PR-1 (ADR-0021 §3, ADR-0020 rule 2) — the host auth-profile
// registry. ONE row per host CLASS (R-A1-7: TENANT | PLATFORM | PORTAL), NOT
// per-tenant: `host_class` is UNIQUE. Resolves a request host to its Cognito
// profile + redirect configuration, replacing (behaviour-preservingly, R-A1-1)
// the split of env allow-lists + per-request tenant DB lookup.
//
// The Cognito profile columns (pool_id/client_id/issuer/domain) are seeded to
// today's single-pool values and are INERT in this PR (R-A1-5: NO multi-pool
// selection logic). Making pool_id a ROW VALUE is the delivered capability —
// pool separation becomes a later DATA operation at class level, not a code
// change. `default_idp` carries the class-default IdP hint; TENANT rows are
// overridden per-request by `tenant.identity_provider` from findActiveBySlug.
model HostAuthProfile {
  id               String   @id @db.Uuid
  // Closed vocabulary: TENANT | PLATFORM | PORTAL. Unique — the class key.
  host_class       String   @unique
  // PLATFORM/PORTAL: the exact host. TENANT: the wildcard/root-domain pattern.
  host_pattern     String
  // Cognito profile — seeded to current values, inert in PR-1 (R-A1-5).
  pool_id          String
  client_id        String
  issuer           String
  domain           String
  // Class-default IdP hint (Home Realm Discovery); null = no hint. TENANT rows
  // are overridden per-request by tenant.identity_provider.
  default_idp      String?
  // Post-login / signout targets — default '/' (current AUTH_POST_LOGIN_PATH /
  // AUTH_SIGNOUT_PATH defaults).
  post_login_path  String   @default("/")
  signout_path     String   @default("/")
  // Soft-disable without deletion.
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  @@schema("auth_storage")
}

model RefreshToken {
  id              String    @id @db.Uuid
  user_id         String    @db.Uuid
  tenant_id       String    @db.Uuid
  consumer_type   String
  token_hash      String    @unique
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  expires_at      DateTime  @db.Timestamptz
  revoked_at      DateTime? @db.Timestamptz
  replaced_by_id  String?   @db.Uuid

  replaced_by     RefreshToken?  @relation("TokenRotation", fields: [replaced_by_id], references: [id])
  replaces        RefreshToken[] @relation("TokenRotation")

  @@index([user_id, tenant_id, consumer_type])
  @@index([replaced_by_id])
  @@index([expires_at])
  @@schema("auth_storage")
}
