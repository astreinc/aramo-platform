// Per-module Prisma schema for the `ingestion` module.
//
// Per Architecture v2.0 Section 7 (Schema-per-Module data architecture) and
// doc/05-conventions.md "Database Conventions". Cross-schema references
// elsewhere in the program are UUID-only without FK constraints.
//
// PR-12 introduces the raw payload reference model (Plan v1.2 §3 M2
// Track A; API Contracts v1.0 Phase 4 — Invariant 7 "Raw payloads are
// stored by reference, not treated as Talent truth"). PR-12 is GENERIC
// ingestion only — passive intake; per-source adapters are later PRs;
// ingestion Pact tests are PR-14; source-consent mapping is PR-13.
//
// The model is Charter-R10-clean (no R10-forbidden output fields).
// Cross-schema tenant_id is UUID-only with no FK (Architecture v2.0 §7).

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ingestion"]
}

// T2-2a — ResolutionMethod enum (NEW). Records HOW the canonicalize
// service was told to associate a payload with a Core Talent. T2-2a
// is ASSOCIATE-NOT-RESOLVE (the caller supplies the id or null); the
// service does NOT compute the decision. T2-3 wires the verified-email
// resolver and may add `sha256_payload_dup`.
//
//   - new_identity         — caller passed `core_talent_id: null`; the
//                            canonicalize service created a fresh
//                            Talent + overlay.
//   - verified_email_match — caller passed an id derived from a
//                            verified-email lookup (T2-3 callers).
//   - caller_supplied      — caller passed an id with no resolution-rule
//                            attribution (e.g. recruiter-direct ingest
//                            paths that bind the payload to a known
//                            Talent).
enum ResolutionMethod {
  new_identity
  // TR-2a-B2 (DDR-2 §6): confirmed_anchor_match is the NEW writable value — a
  // deterministic Tier-A both-sides-confirming resolve. verified_email_match +
  // caller_supplied are HISTORICAL, read-widened (never newly written; the old
  // rows are append-only truth of what the retired rule did). sha256_payload_dup
  // is NOT minted (item-3: no dedup short-circuit records a method).
  confirmed_anchor_match
  verified_email_match
  caller_supplied

  @@schema("ingestion")
}

// RawPayloadReference — the persistence model for the generic ingestion
// path. Mirrors API Contracts v1.0 Phase 4 RawPayloadReference wire
// schema (storage_ref, sha256, content_type, captured_at) and adds the
// persistence-only fields required by Plan §3 M2 Track A: id PK,
// tenant_id, source identifier, dedup-supporting fields
// (verified_email, profile_url), and server-set audit timestamps.
//
// Idempotency-by-content-addressing: a (tenant_id, sha256) pair is
// unique — the same payload bytes submitted twice in a tenant resolve
// to the same row at the persistence layer. The dedup logic in §4.4
// surfaces additional verified-email / profile-URL match signals
// independent of sha256.
//
// PR-12 detects-and-flags duplicates; it does not merge or canonicalize
// (per directive §4.4 and §5).
model RawPayloadReference {
  id              String   @id @default(uuid()) @db.Uuid
  // Cross-schema reference to libs/identity's Tenant — UUID-only,
  // no FK (Architecture v2.0 §7).
  tenant_id       String   @db.Uuid
  // Closed vocabulary (API Contracts v1.0 Phase 4 AdapterType allowed
  // values): talent_direct | indeed | github | astre_import.
  // Implemented as String (not Prisma enum) per the libs/talent /
  // libs/consent precedent.
  source          String
  // TR-2a-B1 (DDR-1 §3.1/§3.2 + §4): the arrival's attestation level, SERVER-
  // derived from `source` via the ingestion channel-source_class map, written
  // once at ingest and NEVER caller-supplied (a caller asserting its own
  // attestation level is self-attestation laundering). Closed vocab mirroring
  // talent_trust SourceClass: SELF for first-party declarations,
  // THIRD_PARTY_UNVERIFIED for github/astre_import/indeed and any unmapped
  // channel (fail-closed default), THIRD_PARTY_VERIFIED only for a channel whose
  // documented semantics attest verification. TEXT column, not a Prisma enum
  // (libs/talent-trust / libs/consent precedent).
  source_class    String
  // RawPayloadReference wire fields (Phase 4 §"Raw Payload Reference Model"):
  storage_ref     String
  sha256          String
  content_type    String
  captured_at     DateTime @db.Timestamptz
  // TR-2a-B2 (Name-Wiring ruling §1): the channel-supplied structured declared
  // name. UNLIKE source_class (an attestation LEVEL, server-derived only), this
  // is a CLAIM — caller/channel-supplied is its nature. Consumed ONLY by the
  // CONFIRMED-arm NAME guard (Amendment §2.1-§2.2), never an identity key.
  // Normalized at write (trim + inner-whitespace collapse; case preserved for
  // display — tokenization normalizes at compare time). Nullable — today's
  // channels supply none, so the guard passes vacuously (absence never conflicts).
  declared_name   String?
  // Dedup-supporting fields (Plan §3 M2 Track A — "verified email
  // match, profile URL match"). Both optional: a given payload may
  // carry one, both, or neither.
  // NOTE (TR-2a-B1 / DDR-1 §3.3): `verified_email` is a documented misnomer —
  // it holds the channel-CLAIMED email, normalized (trim + lowercase), NOT a
  // verified one. The verification level of this value is carried by
  // `source_class`, never by this field's name. Rename to `claimed_email` is a
  // filed non-blocking follow-up, deferred off the source_class substrate change.
  verified_email  String?
  profile_url     String?
  // Skill surface forms (Plan v1.2 §3 M2 Track A — "Skill surface
  // form ingestion; raw forms stored, canonicalization deferred";
  // PR-13 directive §4.4 + Lead ruling). The literal skill strings
  // as they arrive in a payload, stored opaquely. NO skill_id, NO
  // canonical reference — Skills Taxonomy is a separate workstream.
  // Group 2 v2.3a "Skills Taxonomy dependency": "store surface_form
  // only and run canonicalization backfill later."
  skill_surface_forms Json?
  // The canonicalize method-of-resolution record (verified_email_match |
  // new_identity), written with resolved_subject_id in the canonicalize tx.
  resolution_method   ResolutionMethod?
  // Fix-Slice-2 (ADR-0016 D3/D5) — the within-tenant L2 resolution anchor: the
  // talent_trust.ResolutionSubject id this arrival resolved to (verified-email
  // SubjectAnchor match → existing subject, or a new subject). The canonicalize
  // idempotency anchor + poll gate (the husk resolved_talent_id was dropped in
  // Fix-Slice-Final-Drop). DISTINCT from resolved_cluster_id. Nullable — NULL
  // until canonicalize fires. UUID-only, no FK (talent_trust owns the subject).
  resolved_subject_id String?           @db.Uuid
  // Step 4b (ADR-0016) — the cross-tenant resolution anchor: the
  // identity_index.PersonCluster id this payload resolved to (PII-free,
  // fingerprint-matched). DISTINCT from resolved_subject_id (within-tenant L2):
  // one human across tenants shares ONE cluster but a distinct subject per
  // tenant. Nullable — set only when a verified_email produced a fingerprint;
  // no verified email ⇒ no cross-tenant key ⇒ NULL. UUID-only, no FK
  // (cross-schema; identity_index owns PersonCluster).
  resolved_cluster_id String?           @db.Uuid
  // Cold-Ingest Extraction — the async subject-poll's extract-once gate (the
  // analogue of resolved_subject_id's canonicalize-poll gate). A resolved
  // arrival with a résumé storage_ref is picked up by the extraction poll;
  // extraction_done_at is stamped once evidence is written OR the résumé
  // parses with no name (permanent — a name-less résumé must not loop).
  // NULL = still needs extraction. extraction_attempts bounds transient
  // (S3/fetch) retries so a persistently-failing fetch does not spin forever.
  extraction_done_at  DateTime?         @db.Timestamptz
  extraction_attempts Int               @default(0)
  // Server-set audit timestamps.
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  // Content-addressed idempotency at the persistence layer: the same
  // payload bytes within a tenant resolve to a single row.
  @@unique([tenant_id, sha256])
  // Dedup query support — verified-email and profile-URL match within
  // a tenant.
  @@index([tenant_id, verified_email])
  @@index([tenant_id, profile_url])
  @@schema("ingestion")
}
