{
  "name": "field-masking",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/field-masking/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/field-masking",
        "main": "libs/field-masking/src/index.ts",
        "tsConfig": "libs/field-masking/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/field-masking/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root libs/field-masking"
      }
    }
  }
}
