    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@aramo/auth": ["../../dist/libs/auth/src/index.d.ts"],
      "@aramo/authorization": ["../../dist/libs/authorization/src/index.d.ts"],
      "@aramo/common": ["../../dist/libs/common/src/index.d.ts"],
      "@aramo/entitlement": ["../../dist/libs/entitlement/src/index.d.ts"],
      "@aramo/identity-index": ["../../dist/libs/identity-index/src/index.d.ts"],
      "@aramo/object-storage": ["../../dist/libs/object-storage/src/index.d.ts"],
      "@aramo/resume-parse": ["../../dist/libs/resume-parse/src/index.d.ts"],
      "@aramo/talent": ["../../dist/libs/talent/src/index.d.ts"]
