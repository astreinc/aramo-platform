// Per-module Prisma schema for the `talent_record` module — PR-A4 (ATS Batch 3).
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references are UUID-only without FK constraints (§7.3).
//
// PR-A4 Gate 5 (post-amendment) — the recruiter-facing ATS talent
// record. Renamed from "libs/talent" to avoid collision with the
// pre-existing Core libs/talent (tenant-AGNOSTIC identity Talent +
// TalentTenantOverlay, PR-10 baseline).
//
// PR-A5b-2 (the keystone) — the Core-Talent link lands here as an
// additive nullable `core_talent_id` column referencing
// `talent.Talent.id` (Architecture v2.0 §7.3 — UUID-only, no FK).
// The link is set/cleared by TalentLinkService, NEVER by a free PATCH
// (the service runs the two-step in-tenant gate: (1) Talent identity
// exists in Core, (2) this tenant has an overlay for it). The link
// column is the ATS side ONLY — Core `talent.*` schema is unchanged.
// SACRED BOUNDARIES: LINK-NOT-CREATE (the linker NEVER calls
// createTalent / createOverlay — proven structurally by the
// integration spec's bit-identical talent.* row-counts) and
// ASSOCIATE-NOT-RESOLVE (the linker takes core_talent_id as an
// explicit input; the lib carries no `findTalentByEmail` /
// resolveIdentity surface — proven by absence).
//
// Refusals enforced structurally:
//   - R10 — NO portal-forbidden numeric/ordinal fields. The talent
//     record carries identity + contact + recruiter notes ONLY. Any
//     examination output lives in Core (libs/examination); never here.
//   - R12 — locked vocabulary token (`talent`). The model name is
//     `TalentRecord` to disambiguate locally against Core's `Talent`.
//
// Schema-row shape mirrors the A2/A3 pattern (libs/requisition
// exemplar): id uuid PK + tenant_id required + site_id optional +
// created_at/updated_at timestamptz; indexes lead with tenant_id.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["talent_record"]
}

// TalentRecord — the ATS-domain recruiter-facing talent record.
// OpenCATS doc-04 field shapes (the pre-rename ATS person table,
// re-vocabulary-ed per R12). Tenant + site scoped (Architecture §7.2 —
// recruiters in a tenant see all entitled rows; NO assignment filter at
// this entity, unlike requisition).
model TalentRecord {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Required identification.
  first_name String
  last_name  String

  // Contact details.
  email1     String?
  email2     String?
  phone_home String?
  phone_cell String?
  phone_work String?

  // Address (free-text).
  address  String?
  address2 String?
  city     String?
  state    String?
  zip      String?

  // Recruiter-facing CRM fields.
  source             String?
  key_skills         String?
  current_employer   String?
  current_pay        String?
  desired_pay        String?
  date_available     DateTime? @db.Timestamptz
  can_relocate       Boolean   @default(false)
  is_hot             Boolean   @default(false)
  notes              String?
  web_site           String?
  best_time_to_call  String?

  // Talent-STATED categorical fields — Talent Record Spec Amendment
  // (stated-fields) v1.0. String + closed vocabulary (§5; see dto/stated-fields.ts),
  // NOT Prisma enums. availability_status: {available_now|open_to_offers|
  // not_looking|unknown} (null ≠ unknown at the data layer). engagement_type:
  // {contract_to_hire|contract|direct_hire} (null = not stated). Stated, never
  // inferred (R10). Btree-indexed for Segment-4 server-side faceting.
  availability_status String?
  engagement_type     String?

  // Provenance (UUID-only logical refs to identity.User).
  owner_id      String? @db.Uuid
  entered_by_id String? @db.Uuid

  // ADR-0016 step 4d — the TalentTenantOverlay fold. The overlay's
  // tenant-relationship fields move onto the TalentRecord (the ATS heart);
  // the overlay table itself survives until 4e (the ingestion/canonicalize
  // path still writes a per-tenant Core-husk overlay). NULLABLE — ATS-created
  // records have no overlay writer today, so these are unset until the ATS
  // sets the tenant relationship (or the ingestion→TalentRecord association,
  // a later step). Closed vocabularies match the overlay (Talent Record Spec
  // §2.2): source_channel {self_signup|recruiter_capture|referral|import};
  // tenant_status is the per-tenant lifecycle.
  source_channel      String? // closed vocab (overlay parity), nullable on the fold
  tenant_status       String?
  source_recruiter_id String? @db.Uuid

  // ADR-0016 step 4d — the cross-tenant identity pointer: the
  // identity_index.PersonCluster this record belongs to (UUID-only cross-
  // schema ref, no FK per §7.3). Set by TalentLinkService (cluster-exists
  // validated against identity_index). This is the post-realignment identity
  // pointer; core_talent_id (below) stays alongside it during the transition
  // (consent is still Core-keyed and owned by the consent re-key directive),
  // and both retire together in 4e.
  cluster_id String? @db.Uuid

  // PR-A5b-2 — the Core-Talent link (the keystone of the ATS↔Core
  // seam). Logical cross-schema reference to `talent.Talent.id`
  // (Architecture §7.3 — UUID-only, no FK). Nullable: an UNLINKED
  // TalentRecord is valid (most records start unlinked). Set ONLY by
  // TalentLinkService via the dedicated /link routes. UNTOUCHED by 4d —
  // the per-tenant Core husk pointer; consent reads it (consent re-key owns
  // it). LINK-NOT-CREATE: the linker NEVER mutates Core. ASSOCIATE-NOT-
  // RESOLVE: the linker takes this id as an explicit input; the lib
  // carries no identity-resolution surface.
  core_talent_id String? @db.Uuid

  // PR-A8-1 — back-reference to the import batch that created this row
  // (NULL for rows created outside the import engine). Cross-schema
  // logical reference to import.ImportBatch.id (§7.3). THE non-
  // negotiable boundary (directive §0): imports of target_entity
  // 'talent_record' create rows here with `core_talent_id` NULL — the
  // engine NEVER calls Core's createTalent / createOverlay. The
  // bit-identical talent.* row-counts pre/post the import is the
  // load-bearing integration-spec assertion.
  import_batch_id String? @db.Uuid

  // Timestamps.
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Search PR-2 — the dedicated résumé-text row (1:1-latest). The
  // persisted+redacted résumé body lives in TalentResumeText (the
  // PII-isolation model — NOT a column on this core CRM row). The
  // relation carries onDelete: Cascade on the FK side so deleting a
  // TalentRecord PURGES its résumé-text row + the tsvector GIN entry
  // (D1 self-cleaning; the cascade is DB-enforced, not service-path-
  // dependent).
  resume_text TalentResumeText?

  // Indexes — every query path leads with tenant_id; (last, first)
  // serves the dominant "search by name" recruiter query path. PR-A5b-2
  // adds (tenant, core_talent_id) for the "which records in tenant are
  // linked to this Core Talent" query.
  @@index([tenant_id, last_name, first_name])
  @@index([tenant_id, site_id])
  @@index([tenant_id, is_hot])
  @@index([tenant_id, core_talent_id])
  // 4d — "which records in tenant belong to this PERSON_CLUSTER".
  @@index([tenant_id, cluster_id])
  @@index([tenant_id, import_batch_id])
  // Segment-4 server-side faceting (stated-fields amendment §5).
  @@index([tenant_id, availability_status])
  @@index([tenant_id, engagement_type])
  // Segment-4 keyset cursor sort orders (sort key + id tiebreak). The
  // key_skills pg_trgm GIN is hand-authored in the migration (Prisma can't
  // express gin_trgm_ops).
  @@index([tenant_id, created_at, id])
  @@index([tenant_id, owner_id, id])
  @@index([tenant_id, city, state, id])

  @@schema("talent_record")
}

// Search PR-2 — the persisted, redacted résumé body text for content-
// search. Authorized by the ADR-0015 Addendum (Résumé-Text-Persistence):
// the parse pipeline DISCARDS the text today; PR-2 RE-EXTRACTS it post-
// create (from the retained S3 file) keyed to the real talent_record_id,
// redacts SSN-shaped patterns at persist (D4), and indexes it.
//
// PII-isolation model (addendum §3): a DEDICATED table, NOT a column on
// TalentRecord — so erasure has a single clean target and the large
// free-text PII blob stays off the core entity. Same-schema (talent_record)
// with a real FK → the D1 purge-on-delete cascade is a DB guarantee.
//
// 1:1-latest (talent_record_id @unique): re-attaching a résumé upserts
// this row back to `pending` (versioning is a registered follow-on, not
// v1). `storage_key` is the re-extract source pointer (the attachment's
// S3 key, passed at enqueue — talent-record never reads the attachment
// schema, which would cycle).
//
// The `search_tsv` generated tsvector column + its GIN index are added
// by the hand-authored migration (Prisma cannot express GENERATED ALWAYS
// / tsvector); declared here as Unsupported so the schema is drift-free.
model TalentResumeText {
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @db.Uuid

  // 1:1-latest FK to the owning TalentRecord (same-schema → onDelete
  // Cascade is the D1 purge guarantee).
  talent_record_id String @unique @db.Uuid

  // Provenance: which résumé Attachment produced this text. Cross-schema
  // (attachment schema) → UUID-only, NO FK (§7.3). Re-extract source
  // pointer lives alongside.
  attachment_id String? @db.Uuid
  storage_key   String?

  // Lifecycle: 'pending' (enqueued at résumé-attachment commit, awaiting
  // the async re-extract) | 'extracted' (text persisted + indexed) |
  // 'failed' (extraction failed; re-enqueue replays). Pending/failed rows
  // carry no text → empty tsvector → never match a ?resume_q= (correct).
  status String @default("pending")

  // The REDACTED résumé body (SSN-shaped patterns removed at persist —
  // D4). What is indexed + snippet-shown. Nullable while pending.
  redacted_text String?

  // The generated full-text index column — GENERATED ALWAYS AS
  // (to_tsvector('english', coalesce(redacted_text,''))) STORED, with a
  // GIN index. Declared Unsupported (Prisma cannot model it); the
  // migration owns its definition. Never written by Prisma.
  search_tsv Unsupported("tsvector")?

  extracted_at DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz

  talent_record TalentRecord @relation(fields: [talent_record_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([status])
  // The directive names the table `talent_resume_text` (snake); the Prisma
  // model is PascalCase, so @@map binds the client to the real table. Field
  // names already match their snake columns (no per-field @map needed).
  @@map("talent_resume_text")
  @@schema("talent_record")
}
