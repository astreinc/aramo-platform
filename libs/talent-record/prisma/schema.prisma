// Per-module Prisma schema for the `talent_record` module — PR-A4 (ATS Batch 3).
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references are UUID-only without FK constraints (§7.3).
//
// PR-A4 Gate 5 (post-amendment) — the recruiter-facing ATS talent
// record. Renamed from "libs/talent" to avoid collision with the
// pre-existing Core libs/talent (tenant-AGNOSTIC identity Talent +
// TalentTenantOverlay, PR-10 baseline).
//
// PR-A5b-2 (the keystone) — the Core-Talent link lands here as an
// additive nullable `core_talent_id` column referencing
// `talent.Talent.id` (Architecture v2.0 §7.3 — UUID-only, no FK).
// The link is set/cleared by TalentLinkService, NEVER by a free PATCH
// (the service runs the two-step in-tenant gate: (1) Talent identity
// exists in Core, (2) this tenant has an overlay for it). The link
// column is the ATS side ONLY — Core `talent.*` schema is unchanged.
// SACRED BOUNDARIES: LINK-NOT-CREATE (the linker NEVER calls
// createTalent / createOverlay — proven structurally by the
// integration spec's bit-identical talent.* row-counts) and
// ASSOCIATE-NOT-RESOLVE (the linker takes core_talent_id as an
// explicit input; the lib carries no `findTalentByEmail` /
// resolveIdentity surface — proven by absence).
//
// Refusals enforced structurally:
//   - R10 — NO portal-forbidden numeric/ordinal fields. The talent
//     record carries identity + contact + recruiter notes ONLY. Any
//     examination output lives in Core (libs/examination); never here.
//   - R12 — locked vocabulary token (`talent`). The model name is
//     `TalentRecord` to disambiguate locally against Core's `Talent`.
//
// Schema-row shape mirrors the A2/A3 pattern (libs/requisition
// exemplar): id uuid PK + tenant_id required + site_id optional +
// created_at/updated_at timestamptz; indexes lead with tenant_id.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["talent_record"]
}

// TalentRecord — the ATS-domain recruiter-facing talent record.
// OpenCATS doc-04 field shapes (the pre-rename ATS person table,
// re-vocabulary-ed per R12). Tenant + site scoped (Architecture §7.2 —
// recruiters in a tenant see all entitled rows; NO assignment filter at
// this entity, unlike requisition).
model TalentRecord {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Required identification.
  first_name String
  last_name  String

  // Contact details.
  email1     String?
  email2     String?
  phone_home String?
  phone_cell String?
  phone_work String?

  // Address (free-text).
  address  String?
  address2 String?
  city     String?
  state    String?
  zip      String?

  // Recruiter-facing CRM fields.
  source             String?
  key_skills         String?
  current_employer   String?
  current_pay        String?
  desired_pay        String?
  date_available     DateTime? @db.Timestamptz
  can_relocate       Boolean   @default(false)
  is_hot             Boolean   @default(false)
  notes              String?
  web_site           String?
  best_time_to_call  String?

  // Provenance (UUID-only logical refs to identity.User).
  owner_id      String? @db.Uuid
  entered_by_id String? @db.Uuid

  // PR-A5b-2 — the Core-Talent link (the keystone of the ATS↔Core
  // seam). Logical cross-schema reference to `talent.Talent.id`
  // (Architecture §7.3 — UUID-only, no FK). Nullable: an UNLINKED
  // TalentRecord is valid (most records start unlinked). Set ONLY by
  // TalentLinkService via the dedicated /link routes; the in-tenant
  // gate is the existence of a TalentTenantOverlay for
  // (talent_id = core_talent_id, tenant_id = record.tenant_id).
  // LINK-NOT-CREATE: the linker NEVER mutates Core. ASSOCIATE-NOT-
  // RESOLVE: the linker takes this id as an explicit input; the lib
  // carries no identity-resolution surface.
  core_talent_id String? @db.Uuid

  // PR-A8-1 — back-reference to the import batch that created this row
  // (NULL for rows created outside the import engine). Cross-schema
  // logical reference to import.ImportBatch.id (§7.3). THE non-
  // negotiable boundary (directive §0): imports of target_entity
  // 'talent_record' create rows here with `core_talent_id` NULL — the
  // engine NEVER calls Core's createTalent / createOverlay. The
  // bit-identical talent.* row-counts pre/post the import is the
  // load-bearing integration-spec assertion.
  import_batch_id String? @db.Uuid

  // Timestamps.
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Indexes — every query path leads with tenant_id; (last, first)
  // serves the dominant "search by name" recruiter query path. PR-A5b-2
  // adds (tenant, core_talent_id) for the "which records in tenant are
  // linked to this Core Talent" query.
  @@index([tenant_id, last_name, first_name])
  @@index([tenant_id, site_id])
  @@index([tenant_id, is_hot])
  @@index([tenant_id, core_talent_id])
  @@index([tenant_id, import_batch_id])

  @@schema("talent_record")
}
