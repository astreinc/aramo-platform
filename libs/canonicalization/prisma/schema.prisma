// Per-module Prisma schema for the `canonicalization` module ‚Äî T2-2a
// (the orchestration half of T2-2; T2-2b adds the outbox-publisher drain).
//
// Per Architecture v2.0 ¬ß7 (Schema-per-Module data architecture) +
// doc/05-conventions.md "Database Conventions". Cross-schema references
// elsewhere in the program are UUID-only without FK constraints (¬ß7.3).
//
// Per T2-2a Directive ¬ß1 Ruling 1 (Lead-approved Option A): canonicalization
// is an orchestrator that spans 4 PG schemas in ONE Prisma client ‚Äî it owns
// the new `canonicalization` schema (OutboxEvent) and reads/writes the
// participant schemas (`talent`, `talent_evidence`, `ingestion`) as
// FOLLOWERS. The follower models are duplicated verbatim from the
// source-of-truth schema.prisma in each owning lib; the duplication is
// guarded by the MANDATORY drift-tripwire CI test
// (libs/canonicalization/src/tests/follower-drift.spec.ts) which asserts
// each follower's (column names, types, nullability) is bit-identical to
// the source ‚Äî the condition of Option A's approval (¬ß1 Ruling 2).
//
// Migration ownership (¬ß1 Ruling 3 ‚Äî HARD REQUIREMENT): canonicalization's
// migrations own ONLY the `canonicalization` PG schema. The followed
// models (`talent`, `talent_evidence`, `ingestion`) already exist; this
// lib's migrations MUST produce NO migration against them (no recreate,
// no alter). The init migration is hand-written to create exactly
// `canonicalization` schema + OutboxEvent table, mirroring the
// libs/submittal add_outbox_event additive precedent.
//
// Isolation (¬ß1 Ruling 4): the atomic `canonicalize` $transaction runs at
// READ COMMITTED + a SELECT ‚Ä¶ FOR UPDATE on the RawPayloadReference row
// at the top ‚Äî prevents the concurrent-canonicalize race without
// SERIALIZABLE's cost.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  // Fix-Slice-Final-Drop ‚Äî the multi-schema client is down to 2 schemas.
  // The talent + talent_evidence followers were dropped with the husk (the
  // mint is retired; canonicalize no longer follows those schemas). Order:
  //   - canonicalization: OWNED (OutboxEvent table).
  //   - ingestion: FOLLOWED (RawPayloadReference + ResolutionMethod enum).
  schemas  = ["canonicalization", "ingestion"]
}

// ===========================================================================
// OWNED MODELS ‚Äî canonicalization PG schema
// ===========================================================================

// T2-2a ‚Äî canonicalization OutboxEvent (NEW table; T2-2a writes, T2-2b
// drains). Per Architecture v2.0 ¬ß7.6 the per-module outbox precedent
// established by libs/consent (M5 PR-11) and extended to libs/submittal
// (M6 PR-2). Shape mirrors libs/consent.OutboxEvent +
// libs/submittal.OutboxEvent verbatim ‚Äî six columns, no
// aggregate_type/aggregate_id (aggregate identity lives inside
// event_payload). Drained by libs/outbox-publisher at T2-2b (the publisher
// gains a 4th-schema drain; the split seam per the Directive's ¬ß0).
//
// T2-2a writes `talent.canonicalized` events into this table IN THE
// canonicalize $transaction (the outbox invariant ‚Äî the event must commit
// atomically with the state change; partial canonicalization is a corrupt
// identity per ¬ß1 Ruling 1's atomicity requirement).
model OutboxEvent {
  id            String    @id @db.Uuid
  tenant_id     String    @db.Uuid
  event_type    String
  event_payload Json
  created_at    DateTime  @default(now()) @db.Timestamptz
  published_at  DateTime? @db.Timestamptz

  @@index([published_at])
  @@schema("canonicalization")
}

// ===========================================================================
// FOLLOWED MODELS ‚Äî ingestion PG schema
// Source of truth: libs/ingestion/prisma/schema.prisma.
// The follower mirrors the source bit-identically (follower-drift tripwire).
// resolved_subject_id is the live L2 anchor; resolved_talent_id was dropped
// with the husk (Fix-Slice-Final-Drop).
// ===========================================================================

enum ResolutionMethod {
  new_identity
  verified_email_match
  caller_supplied

  @@schema("ingestion")
}

model RawPayloadReference {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid
  source          String
  // TR-2a-B1 (DDR-1 ¬ß3.1) ‚Äî FOLLOWER mirror of ingestion.RawPayloadReference.
  // The arrival's server-derived attestation level canonicalize reads and threads
  // to the resolver's writes. Bit-identical to source-of-truth per follower-drift.
  source_class    String
  storage_ref     String
  sha256          String
  content_type    String
  captured_at     DateTime @db.Timestamptz
  verified_email  String?
  profile_url     String?
  skill_surface_forms Json?

  // The canonicalize idempotency anchor + method-of-resolution record.
  // resolved_subject_id (the within-tenant L2 ResolutionSubject) is the LAST
  // write in the canonicalize $transaction + the poll gate; a non-null value
  // short-circuits re-canonicalization. resolved_cluster_id is the 4b
  // cross-tenant PersonCluster anchor. resolution_method = verified_email_match
  // | new_identity.
  resolution_method   ResolutionMethod?
  resolved_subject_id String?           @db.Uuid
  resolved_cluster_id String?           @db.Uuid
  // Cold-Ingest Extraction follower mirror (bit-identical to ingestion ‚Äî the
  // drift tripwire enforces). canonicalize does not read/write these; the
  // extraction poll (its own cip lib) owns them.
  extraction_done_at  DateTime?         @db.Timestamptz
  extraction_attempts Int               @default(0)

  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  @@unique([tenant_id, sha256])
  @@index([tenant_id, verified_email])
  @@index([tenant_id, profile_url])
  @@schema("ingestion")
}
