{
  "name": "metering",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/metering/src",
  "projectType": "library",
  "tags": ["scope:shared"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/metering",
        "main": "libs/metering/src/index.ts",
        "tsConfig": "libs/metering/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/metering/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root libs/metering"
      }
    }
  }
}
