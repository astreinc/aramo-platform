{
  "name": "sourced-talent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/sourced-talent/src",
  "projectType": "library",
  "tags": ["scope:cip"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/sourced-talent",
        "main": "libs/sourced-talent/src/index.ts",
        "tsConfig": "libs/sourced-talent/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/sourced-talent/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root libs/sourced-talent"
      }
    }
  }
}
