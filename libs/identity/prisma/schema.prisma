// Per-module Prisma schema for the `identity` module.
//
// Per Architecture v2.0 Section 7 (Schema-per-Module data architecture) and
// doc/05-conventions.md "Database Conventions". Cross-schema references
// elsewhere in the program are UUID-only without FK constraints.
//
// PR-8.0a-prereq establishes the identity substrate: ten durable identity
// primitives + audit stream. No HTTP controllers, no token issuance, no
// runtime user creation.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["identity"]
}

model User {
  id              String   @id @db.Uuid
  email           String   @unique
  display_name    String?
  is_active       Boolean  @default(true)
  deactivated_at  DateTime? @db.Timestamptz
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  memberships     UserTenantMembership[]
  external_identities ExternalIdentity[]

  // AUTHZ-D4a — Axis-1 management hierarchy (intra-schema FK both ends).
  managed_edges       ManagementEdge[] @relation("ManagementEdgeManager")
  reporting_edges     ManagementEdge[] @relation("ManagementEdgeReport")
  // AUTHZ-D4a — Axis-2 account-ownership pods (AM-anchored Teams + Membership).
  owned_teams         Team[]           @relation("TeamOwner")
  team_memberships    TeamMembership[]

  @@index([is_active])
  @@schema("identity")
}

model Tenant {
  id           String   @id @db.Uuid
  name         String
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  memberships  UserTenantMembership[]
  sites        Site[]

  @@index([is_active])
  @@schema("identity")
}

// Site — sub-tenant partition within a Tenant (PR-A1a Ruling 4). A site
// belongs to exactly one Tenant; memberships and JWT claims may optionally
// reference a Site to scope authority to a sub-tenant. The Site axis lives
// in identity ONLY — no Core (non-identity) schema carries site_id; Core
// stays tenant_id-only per Ruling 4. Sites are additive: tenants without
// any rows in this table behave exactly as before A1a.
model Site {
  id           String   @id @db.Uuid
  tenant_id    String   @db.Uuid
  name         String
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  memberships  UserTenantMembership[]

  @@unique([tenant_id, name])
  @@index([tenant_id, is_active])
  @@schema("identity")
}

model UserTenantMembership {
  id           String   @id @db.Uuid
  user_id      String   @db.Uuid
  tenant_id    String   @db.Uuid
  // Optional site partition (PR-A1a Ruling 4). NULL = tenant-wide membership
  // (existing behavior pre-A1a, preserved); set = site-scoped membership.
  site_id      String?  @db.Uuid
  is_active    Boolean  @default(true)
  joined_at    DateTime @default(now()) @db.Timestamptz
  deactivated_at DateTime? @db.Timestamptz
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  user         User     @relation(fields: [user_id], references: [id])
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  site         Site?    @relation(fields: [site_id], references: [id])
  role_assignments UserTenantMembershipRole[]

  @@unique([user_id, tenant_id])
  @@index([tenant_id, is_active])
  @@index([user_id, is_active])
  @@index([tenant_id, site_id, is_active])
  @@schema("identity")
}

model Role {
  id           String   @id @db.Uuid
  key          String   @unique
  description  String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  role_scopes  RoleScope[]
  membership_assignments UserTenantMembershipRole[]

  @@index([is_active])
  @@schema("identity")
}

model Scope {
  id           String   @id @db.Uuid
  key          String   @unique
  description  String?
  created_at   DateTime @default(now()) @db.Timestamptz

  role_scopes  RoleScope[]

  @@schema("identity")
}

model RoleScope {
  id           String   @id @db.Uuid
  role_id      String   @db.Uuid
  scope_id     String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  role         Role     @relation(fields: [role_id], references: [id])
  scope        Scope    @relation(fields: [scope_id], references: [id])

  @@unique([role_id, scope_id])
  @@schema("identity")
}

model UserTenantMembershipRole {
  id            String   @id @db.Uuid
  membership_id String   @db.Uuid
  role_id       String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz

  membership    UserTenantMembership @relation(fields: [membership_id], references: [id])
  role          Role                 @relation(fields: [role_id], references: [id])

  @@unique([membership_id, role_id])
  @@schema("identity")
}

model ServiceAccount {
  id           String   @id @db.Uuid
  name         String   @unique
  description  String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  @@index([is_active])
  @@schema("identity")
}

model ExternalIdentity {
  id               String   @id @db.Uuid
  provider         String
  provider_subject String
  user_id          String   @db.Uuid
  email_snapshot   String?
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  user             User     @relation(fields: [user_id], references: [id])

  @@unique([provider, provider_subject])
  @@index([user_id])
  @@schema("identity")
}

// IdentityAuditEvent — parallel to ConsentAuditEvent, separate audit stream.
// tenant_id is nullable for global/system events; see directive §6
// event_type → index-category mapping for which events target which index.
model IdentityAuditEvent {
  id             String   @id @db.Uuid
  tenant_id      String?  @db.Uuid
  actor_id       String?  @db.Uuid
  actor_type     String
  event_type     String
  subject_id     String   @db.Uuid
  event_payload  Json
  created_at     DateTime @default(now()) @db.Timestamptz

  // Tenant-scoped keyset traversal: (tenant_id, subject_id, created_at DESC, id DESC).
  @@index([tenant_id, subject_id, created_at(sort: Desc), id(sort: Desc)])
  // Global/system keyset traversal: (created_at DESC, id DESC).
  @@index([created_at(sort: Desc), id(sort: Desc)])
  @@schema("identity")
}

// =============================================================================
// AUTHZ-D4a — the team-model substrate (WRITE-SIDE only; D4b enforces).
// Three greenfield relationship families introduced in PR 2 of the re-sequenced
// authorization build (DDR Amendment v1.1 §4/§6). D4a stores; D4b's composed
// visibility predicate reads these to filter the 6 entities. AFTER D4a, no
// entity's read behavior changes — D4a is pure-additive substrate.
// =============================================================================

// ManagementEdge — Axis-1 management hierarchy (Amendment §4 / §5 / §6).
// Many-to-many manager-user -> report-user; a user may have multiple managers
// (e.g. matrixed reporting), and a manager may have multiple reports.
//
// Both endpoints are identity.User (intra-schema FKs — conventional Prisma
// relations). Cycle-prevented at edge-create (the cycle-check walks upward
// from report_user_id; if manager_user_id appears in the ancestor set the
// edge is rejected with MANAGEMENT_CYCLE_REJECTED 409). Depth cap (3) is a
// read-side concern enforced by D4b's traversal — not by edge-create — so
// an org may have a deeper reporting chain than the visibility cap.
model ManagementEdge {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_id        String   @db.Uuid

  // Intra-schema FKs to identity.User on both endpoints.
  manager_user_id  String   @db.Uuid
  report_user_id   String   @db.Uuid
  manager          User     @relation("ManagementEdgeManager", fields: [manager_user_id], references: [id])
  report           User     @relation("ManagementEdgeReport",  fields: [report_user_id],  references: [id])

  // Provenance.
  created_at       DateTime @default(now()) @db.Timestamptz
  created_by_id    String?  @db.Uuid

  // D4b read paths:
  //   "all reports of manager X in tenant T"  -> (tenant_id, manager_user_id)
  //   "all managers of report Y in tenant T"  -> (tenant_id, report_user_id)
  @@index([tenant_id, manager_user_id])
  @@index([tenant_id, report_user_id])

  // One edge per (manager, report) — re-set is a no-op (idempotent).
  @@unique([manager_user_id, report_user_id])

  @@schema("identity")
}

// Team — Axis-2 account-ownership pod (Amendment §4 / §5.4 AM-anchored).
// A pod owns a set of clients (via TeamClientOwnership in libs/company); pod
// members (via TeamMembership) see the pod's owned clients. AM-anchored:
// one AM per pod via owner_user_id (Lead Gate-5 ruling — co-AMs deferred to a
// future amendment). Many-to-many at the user side (a user may belong to
// multiple pods).
model Team {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid
  name            String

  // AM-anchor (Amendment §5.4). Intra-schema FK to identity.User.
  owner_user_id   String   @db.Uuid
  owner           User     @relation("TeamOwner", fields: [owner_user_id], references: [id])

  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  memberships     TeamMembership[]

  @@unique([tenant_id, name])
  @@index([tenant_id, owner_user_id])
  @@index([tenant_id, is_active])
  @@schema("identity")
}

// TeamMembership — pod membership (many-to-many user ↔ Team). Intra-schema
// FKs to both Team and User. Cascade delete from Team (when a Team row is
// hard-deleted, its memberships drop; soft-deactivate via Team.is_active is
// the recommended path).
model TeamMembership {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid

  team_id         String   @db.Uuid
  team            Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)

  user_id         String   @db.Uuid
  user            User     @relation(fields: [user_id], references: [id])

  added_at        DateTime @default(now()) @db.Timestamptz
  added_by_id     String?  @db.Uuid

  // D4b read paths:
  //   "all pods user X is in (tenant T)"      -> (tenant_id, user_id)
  //   "all members of pod P"                  -> (team_id) via @@unique
  @@unique([team_id, user_id])
  @@index([tenant_id, user_id])
  @@schema("identity")
}
