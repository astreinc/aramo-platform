{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/libs/identity",
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "tsBuildInfoFile": "../../dist/libs/identity/.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@aramo/common": ["../../dist/libs/common/src/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/tests/**/*", "**/*.spec.ts"]
}
