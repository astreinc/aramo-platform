// Per-module Prisma schema for the `attachment` module — PR-A4 (ATS Batch 3).
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references UUID-only, no FK (§7.3).
//
// PR-A4 Gate 5 — the polymorphic file-attachment leaf. Owner_type is a
// typed enum (directive §4 ruling) — all 4 ATS owners (talent /
// requisition / company / contact) DEFINED NOW so later batches can
// reuse the table without a schema migration. A4 wires + tests the
// `talent` owner path ONLY (owner_id resolves against
// `talent_record.TalentRecord` — the ATS recruiter-facing record, NOT
// Core `talent.Talent`; amendment §5).
//
// Service-layer owner validation (controller / service) is what makes
// the typed-discriminator integrity work: at attach time, the service
// reads `owner_type` and validates `owner_id` against the matching
// repository (talent → TalentRecordRepository.findById). Bad or
// cross-tenant owner_id → reject. This integrity is the design item
// that distinguishes this from OpenCATS's untyped no-constraint blob
// table.
//
// Blob storage: this schema records METADATA + `storage_key` only. The
// actual blob upload/download is a presigned-URL step backed by the
// M6 PR-6 object-storage service. At A4, `storage_key` is a free-form
// string (the caller / a future presigned-URL endpoint owns the
// format); the API does NOT host blob bytes.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["attachment"]
}

// AttachmentOwnerType — directive §4 ruling. All 4 ATS owners are
// defined now; future batches (A5+) wire the remaining paths without
// a schema migration.
enum AttachmentOwnerType {
  talent
  requisition
  company
  contact

  @@schema("attachment")
}

// Attachment — polymorphic file-attachment row. Tenant + site scoped.
// owner_type + owner_id form the discriminated pointer to the owner
// row; resolution lives at the service layer (not as a Prisma relation,
// because the owner is in a different PG namespace and §7.3 forbids
// cross-schema FK).
model Attachment {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Polymorphic owner pointer — the typed discriminator (§4 ruling).
  owner_type AttachmentOwnerType
  owner_id   String              @db.Uuid

  // File metadata.
  file_name    String
  mime         String
  size_bytes   Int

  // Object-storage reference (NOT the blob; the M6 PR-6 service holds
  // the bytes).
  storage_key  String

  // ATS-domain flag — true for resume attachments on `talent` owners.
  is_resume Boolean @default(false)

  // Provenance.
  uploaded_by_id String?   @db.Uuid
  uploaded_at    DateTime  @default(now()) @db.Timestamptz

  // Timestamps.
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Index — the dominant "list attachments for owner X" query path
  // (e.g. "all resumes on talent T").
  @@index([tenant_id, owner_type, owner_id])
  @@index([tenant_id, site_id])

  @@schema("attachment")
}
