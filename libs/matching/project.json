{
  "name": "matching",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/matching/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/matching",
        "main": "libs/matching/src/index.ts",
        "tsConfig": "libs/matching/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/matching/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root libs/matching"
      }
    }
  }
}
