// Per-module Prisma schema for the `company` module — PR-A2 (ATS Batch 1).
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references are UUID-only without FK constraints (§7.3).
//
// PR-A2 Gate 5 — first ATS-domain reference-data leaf alongside `contact`.
// Mirrors the existing domain-lib pattern (Ruling 6 — pattern-setter).
// Plain CRUD entity per Ruling 7: no state machine, no event log, no
// metering emits, no outbox.
//
// Tenant + site axes per the PR-A1 tenancy foundation:
//   - tenant_id is REQUIRED on every row (tenant axis, Architecture §7.2).
//   - site_id is OPTIONAL (tenant-wide rows are allowed when site_id is
//     NULL; site-scoped rows carry it). Routes that take a site_id and
//     are marked @RequireSiteMatch enforce that the JWT site claim
//     matches the requested site.
//
// Cross-schema references (Architecture §7.3 — UUID-only, no FK):
//   - billing_contact_id: logical reference to contact.Contact, resolved
//     at read time. Deliberately NOT a hard FK — the inverse FK would
//     create a contact -> company -> contact back-edge at the DB level
//     and a circular leaf-import edge in nx-boundaries. The logical
//     reference preserves the directional contact -> company leaf edge
//     (Ruling 1 — no cycle).
//   - owner_id / entered_by_id: logical identity.User references.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["company"]
}

// Company — the ATS-domain client/employer entity. OpenCATS doc-04
// field shapes; greenfield port with the canonical Aramo tenant + site
// axes added.
model Company {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Required identification.
  name String

  // Address (free-text — no separate Address entity at this batch).
  address  String?
  address2 String?
  city     String?
  state    String?
  zip      String?

  // Contact details on the company itself.
  phone1     String?
  phone2     String?
  fax_number String?
  url        String?

  // ATS-domain freeform metadata.
  key_technologies String?
  notes            String?
  is_hot           Boolean @default(false)

  // Company-Fields v1.1 — UN-GATED additive columns (all optional/defaulted;
  // String-not-enum per R5; closed-vocab values documented inline).
  // Identity / lifecycle.
  status      String  @default("active") // prospect|active|inactive|do_not_contact
  description String?
  industry    String?
  // Address completion (the existing address block has no country).
  country String?
  // Firmographics.
  employee_count_band String? // free-text band label (e.g. "11-50")
  annual_revenue_band String?
  founded_year        Int?
  ownership_type      String? // private|public|nonprofit|government
  registration_number String?
  // Relationship.
  source          String?
  client_tier     String?  // a|b|c
  supplier_status String?  // preferred|approved|exclusive|open
  exclusivity     Boolean  @default(false)
  tags            String[] @default([])
  // Contact completion.
  general_email String?
  // Activity rollup — populated by other surfaces; nullable now, wired later.
  last_activity_at DateTime? @db.Timestamptz
  next_action_at   DateTime? @db.Timestamptz

  // Company-Fields v1.1 — GATED (🔒) COMMERCIAL columns. Visibility +
  // writability gated by the `company:read_commercial` scope (read: omitted
  // from CompanyView by the apps/api field-masking interceptor for
  // non-holders; write: stripped at the repository boundary for non-holders).
  // R3: markup is canonical; margin is DERIVED for display, never stored.
  // Perm fee is a SEPARATE field (not a markup). These are DEFAULTS that
  // pre-fill a requisition/placement — NOT the source of truth for revenue.
  fee_model                   String?  // contract|perm|both
  default_contract_markup_pct Decimal? @db.Decimal(6, 2)
  default_perm_fee_pct        Decimal? @db.Decimal(5, 2)
  payment_terms               String?  // e.g. net_30
  credit_status               String?
  default_currency            String?  @default("USD") // ISO-4217

  // Cross-schema logical references (UUID-only, no FK per §7.3).
  billing_contact_id String? @db.Uuid
  owner_id           String? @db.Uuid
  entered_by_id      String? @db.Uuid

  // PR-A8-1 — back-reference to the import batch that created this row
  // (NULL for rows created outside the import engine). The reversion
  // key (deleteMany WHERE import_batch_id = :id) only touches rows
  // created by the batch — manually-created rows are untouched. Cross-
  // schema logical reference to import.ImportBatch.id (§7.3).
  import_batch_id String? @db.Uuid

  // Timestamps. updated_at populates on every row write (reference CRUD —
  // not column-scoped immutable like the workflow entities; no trigger).
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Intra-schema relation to CompanyDepartment (FK below).
  departments CompanyDepartment[]

  // AUTHZ-D4a — intra-schema joins to the D4a join tables (the back-refs
  // for the user-assignment + team-ownership axes; both defined below).
  user_assignments  UserClientAssignment[]
  team_ownerships   TeamClientOwnership[]

  // Indexes — canonical tenant-axis filter + site-axis filter + name lookup.
  @@index([tenant_id, name])
  @@index([tenant_id, site_id])
  @@index([tenant_id, is_hot])
  @@index([tenant_id, import_batch_id])
  // Company-Fields v1.1 — status is the new primary list filter (R5).
  @@index([tenant_id, status])

  @@schema("company")
}

// CompanyDepartment — sub-organization within a Company. Intra-schema
// FK to Company per Architecture §7.3 (cross-schema is the boundary;
// intra-schema FKs are conventional Prisma relations).
model CompanyDepartment {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Parent company (intra-schema FK).
  company_id String  @db.Uuid
  company    Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  // Required identification.
  name String

  // Timestamps.
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Indexes — canonical tenant + parent-company lookup.
  @@index([tenant_id, company_id])
  @@index([tenant_id, site_id])

  @@schema("company")
}

// =============================================================================
// AUTHZ-D4a — the team-model substrate, company-side (WRITE-SIDE only).
// Two greenfield join tables introduced in PR 2 of the re-sequenced
// authorization build (DDR Amendment v1.1 §4/§6). D4a stores; D4b's composed
// visibility predicate reads these to filter the 6 entities. AFTER D4a, no
// entity's read behavior changes — D4a is pure-additive substrate.
//
// Schema-per-module + cross-schema reference (Architecture §7.3): user_id +
// team_id are CROSS-SCHEMA logical references to identity.User and
// identity.Team — UUID-only, NO FK. Mirrors RequisitionAssignment.user_id.
// company_id is an intra-schema FK to Company (conventional Prisma relation).
// =============================================================================

// UserClientAssignment — the direct-assignment axis (Amendment §4 / Lead
// Gate-5 ruling 6). A user is directly assigned to a client (company); D4b
// reads this as the direct-axis contributor to the union predicate.
// Many-to-many; idempotent re-assign (silent no-op via ON CONFLICT DO
// NOTHING — mirrors RequisitionAssignment per Lead Gate-5 ruling 6).
//
// Scope: company:assign (account_manager + tenant_admin + tenant_owner;
// Recruiting Manager does NOT get it — RM manages PEOPLE; client-assignment
// is the AM act, mirroring requisition:assign).
model UserClientAssignment {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_id        String   @db.Uuid

  // Cross-schema logical reference to identity.User (no FK; §7.3).
  user_id          String   @db.Uuid

  // Intra-schema FK to Company.
  company_id       String   @db.Uuid
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  assigned_at      DateTime @default(now()) @db.Timestamptz
  assigned_by_id   String?  @db.Uuid

  // D4b read paths:
  //   "all clients assigned to user X in tenant T"   -> (tenant_id, user_id)
  //   "all users assigned to client C in tenant T"   -> (tenant_id, company_id)
  @@index([tenant_id, user_id])
  @@index([tenant_id, company_id])

  // One assignment per (user, company) — re-assign is idempotent.
  @@unique([user_id, company_id])

  @@schema("company")
}

// TeamClientOwnership — Axis-2 pod -> client linkage. A pod (identity.Team)
// owns a set of clients (company.Company); D4b reads this as the
// pod-clients contributor to the union predicate. Many-to-many: a pod owns
// multiple companies, and a company may be owned by multiple pods.
//
// team_id is a CROSS-SCHEMA logical reference to identity.Team (no FK;
// §7.3); company_id is an intra-schema FK to Company. This mirrors the
// RequisitionAssignment cross-schema pattern (user_id is the logical ref).
// Lifecycle: hard delete of a row is the unlink (no soft-delete on the
// ownership join itself; pod-side soft-state is on Team.is_active).
model TeamClientOwnership {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_id        String   @db.Uuid

  // Cross-schema logical reference to identity.Team (no FK; §7.3).
  team_id          String   @db.Uuid

  // Intra-schema FK to Company.
  company_id       String   @db.Uuid
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  assigned_at      DateTime @default(now()) @db.Timestamptz
  assigned_by_id   String?  @db.Uuid

  // D4b read paths:
  //   "all companies owned by pod P (tenant T)"  -> (tenant_id, team_id)
  //   "all pods owning company C (tenant T)"     -> (tenant_id, company_id)
  @@index([tenant_id, team_id])
  @@index([tenant_id, company_id])

  // One ownership per (team, company) — re-add is idempotent.
  @@unique([team_id, company_id])

  @@schema("company")
}
