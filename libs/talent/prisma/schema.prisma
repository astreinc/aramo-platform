// Per-module Prisma schema for the `talent` module — RETIRED.
//
// Fix-Slice-Final-Drop (ADR-0016 §13 OPEN-5 / D3): the Core husk substrate is
// retired. The `talent.Talent` + `talent.TalentTenantOverlay` tables (and the
// `talent` PG schema) are dropped by the 20260704160000_drop_core_talent
// migration. Nothing mints or reads them after the fix-sequence:
//   - the canonicalization mint was removed (Fix-Slice-2);
//   - the within-tenant identity now lives on talent_trust.ResolutionSubject (L2);
//   - the tenant's system of record is the ATS talent_record.TalentRecord (heart);
//   - cross-tenant resolution is the PII-free identity_index.PersonCluster.
//
// This schema is a lineage tombstone: it owns the drop migration and carries no
// models. The lib's code (TalentService/TalentRepository/TalentModule) was
// removed; @aramo/talent has no importers.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}
