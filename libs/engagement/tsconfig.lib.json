      "@aramo/job-domain": ["../../dist/libs/job-domain/src/index.d.ts"],
      "@aramo/metering": ["../../dist/libs/metering/src/index.d.ts"],
      "@aramo/talent": ["../../dist/libs/talent/src/index.d.ts"],
