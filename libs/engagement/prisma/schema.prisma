// Per-module Prisma schema for the `engagement` module.
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references elsewhere in the program are UUID-only without FK
// constraints (§7.3).
//
// M5 PR-1 — TalentJobEngagement entity foundation. Per Group 2
// Consolidated Baseline v2.0 §2.3b Part 2 Loops 1-5 (binding canonical
// state-machine narrative): the workflow-state entity carrying the
// engagement state machine for the talent+requisition pairing through
// Group 2 §2.3b Part 2 Loops 1-5 (matching, recruiter triage,
// engagement, response, and submittal-handoff).
//
// Eleven-state enumeration per Group 2 §2.3b Part 2 Loops 1-5 verbatim
// (per M5 PR-1 Directive Amendment v1.1 §2; supersedes the audit /
// directive-v1.0 ten-state interim list resolved at doc-lock
// canonical-divergence gate per Plan v1.5 Correction Note v1.0):
//   surfaced, evaluated, engaged, maybe, passed, awaiting_response,
//   responded, in_conversation, not_interested, ready_for_submittal,
//   submitted.
//
// Default state `surfaced` per Loop 1 (`null -> surfaced -> evaluated` —
// matching engine creating an engagement row writes `surfaced`).
//
// Column-scoped immutability per Group 2 §2.3b Loops 1-5 + M5 PR-1
// Directive Amendment v1.1 §3 is enforced at the database layer by a
// BEFORE UPDATE trigger added in the same migration. The trigger:
//   1) rejects any UPDATE that touches a non-state column, and
//   2) rejects any state transition not in the ten-entry legal matrix.
// Mechanism precedent: examination TalentJobExamination column-scoped
// trigger (M3 PR-1, lifecycle_state). Evidence whole-row precedent does
// not apply because the engagement entity has a mutable `state` column.
//
// Cross-schema UUID references (Architecture §7.3 — UUID-only, no FK):
//   - tenant_id: tenant replication per §7.2.
//   - talent_id: references talent.Talent (M3 PR-1).
//   - requisition_id: references job-domain.Requisition (M3 PR-4).
//   - examination_id: nullable references
//     examination.TalentJobExamination (M3 PR-1; engagement may exist
//     before examination is computed; pin-verify lands at M5 PR-8).
// Write-path application-layer validators land at M5 PR-3 (engagement-
// creation write path); PR-1 ships read-only.
//
// No write methods are exposed on the EngagementRepository at PR-1 —
// belt-and-suspenders alongside the column-scoped database trigger
// (per Directive v1.0 Ruling 3). Write methods (createEngagement,
// transitionState) land with M5 PR-3.
//
// No `updated_at` column — only the `state` column is mutable per the
// column-scoped trigger. Snapshot timestamp `created_at` only.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["engagement"]
}

enum EngagementState {
  surfaced
  evaluated
  engaged
  maybe
  passed
  awaiting_response
  responded
  in_conversation
  not_interested
  ready_for_submittal
  submitted

  @@schema("engagement")
}

// M5 PR-2 — TalentEngagementEvent event-log enum. Four event-type values
// per the M5 PR-2 directive §4.1 + Charter v1.2 §4.4 Ruling D event-log
// scope. Closed-list; future event types added via explicit directive
// amendments.
enum EngagementEventType {
  state_transition
  outreach_drafted
  outreach_sent
  response_received
  conversation_started

  @@schema("engagement")
}

// §2.3b Part 2 Loops 1-5 — TalentJobEngagement (workflow-state entity).
// Cross-schema references (`talent_id`, `requisition_id`,
// `examination_id`) are UUID-only per Architecture §7.3.
model TalentJobEngagement {
  // Identity. UUID v7 generated app-side (PR-2 precedent — Postgres 17
  // has no native uuidv7() function).
  id              String  @id @db.Uuid
  tenant_id       String  @db.Uuid

  // Cross-schema references (§7.3 — UUID-only, no FK).
  talent_id       String  @db.Uuid
  requisition_id  String  @db.Uuid
  // examination_id: nullable — engagement may exist before examination
  // is computed. Pin-verify logic lands at M5 PR-8.
  examination_id  String? @db.Uuid

  // Workflow state. Default `surfaced` per Loop 1 (`null -> surfaced ->
  // evaluated` — matching engine creates row in `surfaced`).
  state           EngagementState @default(surfaced)

  // Snapshot creation timestamp. No updated_at — only the `state`
  // column is mutable per the column-scoped immutability trigger.
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  // Lookups: (tenant, talent, requisition) primary lookup (find
  // engagement for given talent+requisition); (tenant, state) state-
  // based filtering; (tenant, examination_id) examination cross-
  // reference filtering.
  @@index([tenant_id, talent_id, requisition_id])
  @@index([tenant_id, state])
  @@index([tenant_id, examination_id])

  // M5 PR-2 — back-reference for the TalentEngagementEvent intra-schema
  // FK. Relation-only field; no column added at the DB layer.
  events          TalentEngagementEvent[]

  @@schema("engagement")
}

// M6 PR-2 — OutboxEvent (engagement schema). Per Architecture v2.0 §7.6,
// the per-module outbox precedent established by consent (M5 PR-11). Shape
// mirrors libs/consent.OutboxEvent verbatim — six columns, no
// aggregate_type/aggregate_id (aggregate identity lives inside
// event_payload). Repository surface mirrors the consent precedent:
// findUnpublishedEvents + markPublished (no insertInTx — emission is
// inline tx.outboxEvent.create inside each consuming repo's $transaction).
// Drained by the relocated outbox-publisher (libs/outbox-publisher).
model OutboxEvent {
  id            String    @id @db.Uuid
  tenant_id     String    @db.Uuid
  event_type    String
  event_payload Json
  created_at    DateTime  @default(now()) @db.Timestamptz
  published_at  DateTime? @db.Timestamptz

  @@index([published_at])
  @@schema("engagement")
}

// M5 PR-2 — TalentEngagementEvent event-log entity. Per Charter v1.2 §4.4
// Ruling D (engagement event-log scope) + M5 PR-2 directive §4.1: an
// append-only audit log of engagement-side workflow events (state
// transitions, outreach sends, responses, conversation starts).
//
// Cardinality: many events per TalentJobEngagement. Intra-schema FK on
// engagement_id (both entities live in the `engagement` schema, so
// constraint enforcement is permitted per Architecture §7.3 — UUID-only
// applies to cross-schema refs).
//
// Append-only / absolute-immutability: enforced at the DB layer by a
// BEFORE UPDATE trigger added in the same migration (M3 PR-2
// TalentConsentEvent + M4 PR-1 TalentJobEvidencePackage absolute-
// immutability precedent — entire row rejected, not column-scoped).
// The repository surface exposes appendEvent (create-only) and read
// methods; no update/upsert/delete paths.
//
// Cross-schema references (Architecture §7.3 — UUID-only, no FK):
//   - tenant_id: tenant replication per §7.2.
// Intra-schema references (FK permitted per §7.3):
//   - engagement_id → TalentJobEngagement.id (this schema).
//
// event_payload is JSONB per §7.4 ("derived snapshots, metadata,
// evidence summaries" — event-log payloads fall under this scope; the
// payload shape varies per event_type and is typed at the application
// layer when consumed).
model TalentEngagementEvent {
  // Identity. UUID v7 generated app-side.
  id              String              @id @db.Uuid
  tenant_id       String              @db.Uuid

  // Intra-schema FK to TalentJobEngagement.
  engagement_id   String              @db.Uuid
  engagement      TalentJobEngagement @relation(fields: [engagement_id], references: [id])

  // Closed-list event type per the EngagementEventType enum.
  event_type      EngagementEventType

  // Per-event-type JSONB payload. Shape varies; typed at consumption
  // sites in M5 PR-3+ when concrete event-emit paths land.
  event_payload   Json

  // Snapshot creation timestamp. No updated_at — entire row is
  // immutable per the absolute-immutability trigger.
  created_at      DateTime            @default(now()) @db.Timestamptz(6)

  // Lookups: (tenant, engagement) primary lookup (events for a given
  // engagement, tenant-scoped); (engagement, created_at) chronological
  // event-log read for a given engagement.
  @@index([tenant_id, engagement_id])
  @@index([engagement_id, created_at])
  @@schema("engagement")
}
