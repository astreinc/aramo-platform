// Per-module Prisma schema for the `talent_trust` module — TR-1
// (Trust Model & Vocabulary, foundation slice).
//
// Per Architecture v2.x §7 (Schema-per-Module data architecture) and
// doc/05-conventions.md "Database Conventions". Cross-schema references
// are UUID-only without FK constraints (§7.3). Intra-schema relations
// (within the `talent_trust` schema) carry real FKs (the cross-schema
// no-FK rule does not apply within a single schema).
//
// TR-1 builds a LEDGER + a VOCABULARY + a materialized rollup. It runs no
// verification (TR-2…TR-10) and makes no accept/reject/sufficiency decision
// (TR-12). The §8 interface (TrustService) is the only public surface.
//
// CLOSED-VOCABULARY DISCIPLINE (PO Ruling 2, this slice): every closed
// vocabulary is a Postgres `String` (TEXT) column with the allowed values
// documented in a `///` comment, enforced at the DTO layer via TS unions +
// class-validator (@IsIn) — NOT a Prisma native enum. This is the
// documented convention (doc/05-conventions.md "Append-Only Event Tables":
// `scope String // ConsentScope enum value`) and the libs/consent /
// libs/identity / libs/talent precedent. Rationale: `assertion_type` is
// extensible (§5.3 — "later slices register more"); native Prisma enums
// would force a migration each time a downstream slice registers a new
// assertion_type. For module uniformity the genuinely-fixed vocabularies
// (source_class, dimension, bands, current_status) follow the same
// String-backed convention — no native enums anywhere in this schema.
//
// IMMUTABILITY (DoD): `EvidenceRecord` assertion content is immutable once
// written — the ONLY mutable column is `current_status` (a projection of
// the latest EvidenceEvent). A BEFORE UPDATE trigger (added in the same
// migration) raises if any column other than `current_status` is changed.
// `EvidenceEvent` and `EvidenceLink` are append-only — whole-row BEFORE
// UPDATE triggers reject any UPDATE (mirrors libs/consent's
// TalentConsentEvent PR-2 precedent). `TrustState` is a projection
// (recomputed on every write, never hand-authored) and is therefore freely
// upsertable — no immutability trigger.

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["talent_trust"]
}

// ResolutionSubject — the resolution-index node (owned by the Intelligence
// layer), the keying target for all evidence. Under the ratified ATS-as-heart
// / Core-as-index model, the ATS TalentRecord is the system-of-record (the
// heart); this node is the index that resolves references to the same human.
// Maps 1:1 to a reference initially and is mergeable later (R6) — the
// merged_into pointer + reversible merge/unmerge IS the index's same-human
// mechanism. Gives TR-6 (cross-persona resolution) / TR-11 (portable trust) a
// merge point without rewriting evidence.
model ResolutionSubject {
  id String @id @db.Uuid

  tenant_id String @db.Uuid

  /// ResolutionSubjectStatus closed vocabulary: ACTIVE | MERGED | SUPERSEDED
  status String @default("ACTIVE")

  // When status = MERGED, points at the surviving subject (R6 / §8 merge
  // capability). Reversible (unmerge clears it). UUID-only — no relation, to
  // avoid a self-referential Prisma relation TR-1 does not need.
  merged_into_subject_id String? @db.Uuid

  // Promotion Gate Slice-B1 — reconcile watermark. last_reconciled_at is the
  // subject-level analogue of the extraction poll's extract-once gate: the
  // reconcile poll selects PROMOTED subjects (carrying an ATS_TALENT_RECORD ref)
  // whose immutable EvidenceRecord history has grown SINCE this stamp (or NULL =
  // never reconciled). Stamped LAST, after enrichment; a transient failure
  // leaves it un-advanced so the next tick re-selects (bounded by
  // reconcile_attempts). "current = projection over retained history" (OPEN-2):
  // L2 is the history, L3 the current — this watermark drives the projection,
  // it is NOT an L3 version/event/log table (the ruling forbids one).
  last_reconciled_at DateTime? @db.Timestamptz
  reconcile_attempts Int       @default(0)

  created_at DateTime @default(now()) @db.Timestamptz

  // Intra-schema relations (real FKs — within the talent_trust schema).
  refs     ResolutionSubjectRef[]
  evidence EvidenceRecord[]
  state    TrustState?
  anchors  SubjectAnchor[]

  // TR-2a-2 within-tenant same-human advisories this subject appears in (as the
  // canonical-lower `a` side or the canonical-higher `b` side of a pair). ADVISORY
  // only — an advisory NEVER changes a subject's status (advise-only, R1).
  match_advisories_a SubjectMatchAdvisory[] @relation("MatchAdvisorySubjectA")
  match_advisories_b SubjectMatchAdvisory[] @relation("MatchAdvisorySubjectB")

  @@index([tenant_id])
  @@index([tenant_id, status])
  // Promotion-Trigger slice B-api — the sourcing-pool list reader keyset-paginates
  // ACTIVE subjects oldest-first; this supports the (tenant_id, status, created_at,
  // id) scan + keyset cursor without a sort.
  @@index([tenant_id, status, created_at, id])
  @@schema("talent_trust")
}

// ResolutionSubjectRef — crosswalk from a resolution-index node to the
// reference(s) it covers. Initially one ref per subject; multiple after a TR-6
// merge. The `ref_type` discriminator keys against the ATS TalentRecord.id
// (ATS_TALENT_RECORD — the system-of-record ref, the heart, tenant-scoped and
// always present), a tenant-spanning person-cluster (PERSON_CLUSTER — an index
// ref, NOT a Core-Talent-SOR ref), a minted ANCHOR, or an L1 sourced_talent
// staging arrival (SOURCED_TALENT — the PRE-PROMOTION attachment point, so
// evidence can accrue against a raw channel arrival before any TalentRecord
// exists; Fix-Slice-1 / Lifecycle Spec §3.2). ref_type is a plain TEXT column
// (no DB CHECK) — a new value is additive at the vocab/DTO layer, no migration.
model ResolutionSubjectRef {
  id String @id @db.Uuid

  subject_id String @db.Uuid
  tenant_id  String @db.Uuid

  /// ResolutionSubjectRefType closed vocabulary:
  ///   ATS_TALENT_RECORD | PERSON_CLUSTER | ANCHOR | SOURCED_TALENT
  ref_type String

  // The external reference value (ATS TalentRecord.id, a person-cluster id, a
  // minted ANCHOR id, or a sourced_talent arrival id). Cross-schema logical
  // reference — UUID-only, no FK.
  ref_id String @db.Uuid

  linked_at   DateTime @default(now()) @db.Timestamptz
  link_source String

  subject ResolutionSubject @relation(fields: [subject_id], references: [id])

  // A given external ref resolves to exactly one subject within a tenant
  // (recordEvidence's resolve-or-create key).
  @@unique([tenant_id, ref_type, ref_id])
  @@index([subject_id])
  @@index([tenant_id])
  @@schema("talent_trust")
}

// EvidenceRecord — the atomic fact. Assertion content is IMMUTABLE once
// written (enforced by the BEFORE UPDATE trigger; only `current_status` is
// mutable). `strength` is the base strength derived from source_class ×
// method at write time (§6.1) and persisted; time-decay (§7) is applied as a
// function of age at rollup-derivation time, so the persisted base is
// immutable too.
model EvidenceRecord {
  id String @id @db.Uuid

  subject_id String @db.Uuid
  tenant_id  String @db.Uuid

  /// TrustDimension closed vocabulary (R1 — four):
  ///   IDENTITY | CLAIMS | CONTINUITY | ELIGIBILITY
  dimension String

  /// assertion_type — extensible typed set (§5.3). TR-1 seeds a starter set
  /// (PHONE_VERIFIED, SKILL, EMPLOYMENT, DEGREE, CERTIFICATION, FACE_MATCH,
  /// LIVENESS, RIGHT_TO_WORK, IDENTITY_DOCUMENT); later slices register more.
  assertion_type String

  // The structured claim (§5.1). JSONB per §7.4 (derived/metadata payload).
  assertion_payload Json

  /// SourceClass independence ladder (§5.2, ordered worthless→authoritative):
  ///   SELF | THIRD_PARTY_UNVERIFIED | THIRD_PARTY_VERIFIED |
  ///   AUTHORITATIVE_ISSUER | CRYPTOGRAPHIC | BIOMETRIC
  source_class String

  // The specific issuer/party (§5.1). JSONB; nullable. Doubles as the
  // independence key for the §6.2 correlated-evidence collapse.
  source_ref Json?

  /// Method closed vocabulary (§5.3):
  ///   SELF_DECLARED | DOCUMENT | API_REGISTRY | SIGNATURE | BIOMETRIC |
  ///   HUMAN_ATTESTED
  method String

  // Derived & persisted base strength (§6.1) — source_class × method. Never
  // surfaced as a talent-level number (R4); it is the band-derivation input.
  strength Float

  collected_at DateTime @db.Timestamptz

  /// DecayProfile closed vocabulary (§7):
  ///   DURABLE | SLOW | MODERATE | FAST | PER_STEP
  decay_profile String

  /// PortabilityClass closed vocabulary (§5.1 / §9):
  ///   TENANT_ONLY | ATTESTATION_PORTABLE
  portability_class String

  // Ruling 5 — AI-produced evidence must be distinguishable. Orthogonal to
  // `method` (an agent may produce DOCUMENT- or API_REGISTRY-method
  // evidence). The ONLY agent accommodation in TR-1: a flag, not a method
  // value. Lets AI-originated evidence be weighted / surfaced / routed to
  // review independently downstream.
  ai_derived Boolean @default(false)

  /// EvidenceStatus — the ONLY mutable column. A projection of the latest
  /// EvidenceEvent, never hand-edited (§5.5):
  ///   PENDING | VALID | STALE | CONTRADICTED | REVOKED | SUPERSEDED | DISPUTED
  current_status String

  // The writing slice (§5.1 created_by).
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz

  subject ResolutionSubject   @relation(fields: [subject_id], references: [id])
  events  EvidenceEvent[]

  @@index([tenant_id, subject_id])
  @@index([tenant_id, subject_id, dimension])
  @@schema("talent_trust")
}

// EvidenceEvent — append-only lifecycle log. This is how `current_status`
// ever changes (§5.5). Immutable — whole-row BEFORE UPDATE trigger rejects
// any UPDATE.
model EvidenceEvent {
  id String @id @db.Uuid

  evidence_id String @db.Uuid
  // tenant_id is not named in the §5.1 EvidenceEvent field list but is added
  // for the program-wide tenant-scoping + indexing convention
  // (doc/05-conventions.md "Tenant ID Required"). Additive, consistent.
  tenant_id String @db.Uuid

  /// EvidenceEventType closed vocabulary (§5.1):
  ///   CREATED | VALIDATED | MARKED_STALE | CONTRADICTED | REVOKED |
  ///   SUPERSEDED | DISPUTED | DISPUTE_RESOLVED
  event_type String

  reason String?

  // The other evidence implicated by this event (e.g. the contradicting /
  // superseding record). UUID-only, no FK. Nullable.
  linked_evidence_id String? @db.Uuid

  actor       String?
  occurred_at DateTime @default(now()) @db.Timestamptz
  // No updated_at — events are immutable.

  evidence EvidenceRecord @relation(fields: [evidence_id], references: [id])

  @@index([tenant_id, evidence_id, occurred_at])
  @@schema("talent_trust")
}

// EvidenceLink — first-class evidence-to-evidence relations (§5.1). Stored
// for CORROBORATES / CONTRADICTS / SUPERSEDES. from/to are kept UUID-only
// (no Prisma relation) to avoid a dual self-referential relation TR-1 does
// not need. Append-only — whole-row BEFORE UPDATE trigger rejects UPDATE.
model EvidenceLink {
  id String @id @db.Uuid

  from_evidence_id String @db.Uuid
  to_evidence_id   String @db.Uuid

  /// EvidenceLinkRelation closed vocabulary (§5.1):
  ///   CORROBORATES | CONTRADICTS | SUPERSEDES
  relation String

  tenant_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id, from_evidence_id])
  @@index([tenant_id, to_evidence_id])
  @@schema("talent_trust")
}

// TrustState — the materialized rollup downstream reads (§5.1). A projection,
// recomputed on every evidence/event write, never authored directly — always
// reconstructible from the ledger + events. 1:1 with ResolutionSubject.
// Per-dimension bands + flags only; no composite talent-level value (R4).
model TrustState {
  subject_id String @id @db.Uuid
  tenant_id  String @db.Uuid

  /// Each band is a PresentationBand closed vocabulary value (§5.4):
  ///   NOT_ESTABLISHED | SELF_ASSERTED | CORROBORATED |
  ///   INDEPENDENTLY_VERIFIED | AUTHORITATIVE
  identity_band    String
  claims_band      String
  continuity_band  String
  eligibility_band String

  open_contradiction_count Int     @default(0)
  stale_evidence_count     Int     @default(0)
  has_open_dispute         Boolean @default(false)

  last_recomputed_at DateTime @db.Timestamptz

  subject ResolutionSubject @relation(fields: [subject_id], references: [id])

  @@index([tenant_id])
  @@schema("talent_trust")
}

// SubjectAnchor — TR-2a-1 within-tenant MATCH INDEX. A thin derived projection
// over the ledger (like TrustState): one row per (subject, anchor_kind,
// normalized_value), pointing back to the anchor EvidenceRecord that IS its
// source of truth (source_evidence_id). NOT a second source of truth — the
// producer writes it in the SAME transaction as the anchor evidence. The
// within-tenant matcher (TR-2a-2) reads this btree index to find subjects
// sharing a normalized identifier; this slice only builds/populates it.
//
// UN-MERGE CONTRACT: keyed to the ORIGIN subject_id and NEVER re-homed on merge
// (mergeSubjects is pointer-only — resolution follows ResolutionSubject.
// merged_into at read time). So an anchor's origin survives merge/unmerge.
//
// WALL: tenant-scoped. The normalized identifier is PII and lives ONLY here
// (talent_trust, tenant-scoped) — NEVER in identity_index (the I14 wall). Cross-
// tenant same-human resolution is identity_index / fingerprints (TR-2b), never
// this table.
model SubjectAnchor {
  id String @id @db.Uuid

  subject_id String @db.Uuid
  tenant_id  String @db.Uuid

  /// AnchorKind closed vocabulary (TR-2a-1): EMAIL | PHONE
  anchor_kind String

  /// The deterministically-normalized identifier the matcher keys on
  /// (email: trim+lowercase; phone: digit-strip — no LLM, Decision 10).
  normalized_value String

  // The anchor EvidenceRecord this row projects (its source of truth).
  // UUID-only logical reference within the schema.
  source_evidence_id String @db.Uuid

  /// SourceClass of the minting evidence (TR-2a-B1, DDR-1 §3.2). Projected
  /// atomically from source_evidence_id inside insertAnchor. Tier is (signal
  /// kind × attestation): only THIRD_PARTY_VERIFIED confirms (isConfirmingAnchor);
  /// SELF / THIRD_PARTY_UNVERIFIED corroborate. Appended, never mutated — a later
  /// verification of the same value mints a NEW row at the higher class (the
  /// extended unique key below), preserving provenance (I10).
  source_class String

  created_at DateTime @default(now()) @db.Timestamptz

  subject ResolutionSubject @relation(fields: [subject_id], references: [id])

  // Idempotency: one anchor row per (tenant, subject, kind, value, class). The
  // producer exists-checks this before writing, so re-run / backfill never
  // duplicates the anchor OR its evidence. source_class is part of the key
  // (DDR-1 §3.2): a value verified later is a NEW append-only row at the higher
  // class, not a mutation — two rows for one value at two classes is correct.
  @@unique([tenant_id, subject_id, anchor_kind, normalized_value, source_class])
  // The matcher's btree surface: subjects sharing a normalized value in-tenant.
  @@index([tenant_id, anchor_kind, normalized_value])
  @@index([subject_id])
  @@schema("talent_trust")
}

// SubjectMatchAdvisory — TR-2a-2 within-tenant SAME-HUMAN ADVISORY. The matcher
// surfaces a pair of ResolutionSubjects in the SAME tenant that share ≥1 normalized
// anchor (SubjectAnchor) and records this advisory for a human reviewer.
//
// ADVISE-ONLY (R1): this record is COUNSEL, never an action. Writing it takes ZERO
// merge action — no mergeSubjects call, no subject status change. A later slice
// (TR-2a-3) resolves the advisory (human-approve / auto-on-verified-Tier-A). Because
// self-declared shared email/phone are CORROBORATORS not verified Tier-A anchors (R2),
// NOTHING here auto-merges — false-merge is structurally impossible in this slice.
//
// The pair is stored CANONICALLY (subject_a_id < subject_b_id by string compare) so a
// given human-pair maps to exactly ONE advisory regardless of discovery direction —
// the unique constraint makes the backfill / re-run idempotent (no A/B vs B/A dup).
//
// PII DISCIPLINE (R3): this row holds only subject refs + anchor-row refs + kinds — it
// NEVER copies a normalized_value. The identifier PII stays in SubjectAnchor. `match_basis`
// points to the shared SubjectAnchor rows by id; a reviewer resolves them to see WHAT matched.
//
// WALL: tenant-scoped, talent_trust-internal (cip). No identity_index, no cross-tenant
// (that is TR-2b / fingerprints), no ats import (I15). Deterministic — no LLM (Decision 10).
model SubjectMatchAdvisory {
  id String @id @db.Uuid

  tenant_id String @db.Uuid

  // Canonical unordered pair (subject_a_id < subject_b_id, string compare).
  subject_a_id String @db.Uuid
  subject_b_id String @db.Uuid

  /// MatchAdviseBand closed vocabulary (TR-2a-2, split-biased/inclusive):
  ///   ADVISE_WEAK (one shared anchor) | ADVISE_STRONG (multiple / multi-kind).
  /// ADVISORY METADATA ONLY — gates NOTHING (nothing merges); it orders a human's queue.
  advise_band String

  // R5 contradiction flag — the pair shares ≥1 anchor of one kind but has
  // NON-overlapping values on another shared-capable kind (e.g. same email,
  // different phone). Lowers reviewer confidence; split-bias earning its keep.
  has_contradiction Boolean @default(false)

  // The shared + contradicting anchor references — PII-FREE (kinds + SubjectAnchor
  // row ids, never the normalized_value). Shape (§R3):
  //   { shared: [{ anchor_kind, a_anchor_id, b_anchor_id }],
  //     contradiction_kinds: [AnchorKind, …] }
  match_basis Json

  /// MatchAdvisoryStatus closed vocabulary (TR-2a-2 seed → TR-2a-3 lifecycle):
  ///   PENDING_REVIEW | MERGED | DISMISSED | REVERSED
  /// TR-2a-2 writes PENDING_REVIEW only; TR-2a-3 transitions it (append-style — the
  /// advisory is never deleted, its resolution/reversal audit is layered on).
  status String @default("PENDING_REVIEW")

  created_by String
  created_at DateTime @default(now()) @db.Timestamptz

  // ---- TR-2a-3 resolution audit (R4) — every action records actor/time/why ----
  // The advisory is the PRIMARY record of its own resolution (libs/audit is a stub;
  // no general event stream to also-emit to). All nullable until first resolved.

  /// MatchResolutionAction closed vocabulary: MERGE | DISMISS | REVERSE.
  resolution_action String?

  // Who resolved it + when (actor id from the privileged caller, JWT sub).
  resolved_by String?
  resolved_at DateTime? @db.Timestamptz

  // Reviewer justification. REQUIRED to override a has_contradiction=true advisory
  // (R3 — the F34 explicit-acknowledgment+justification override); otherwise optional.
  resolution_justification String?

  // On MERGE (R2 un-merge contract): the surviving subject + the subject whose status
  // became MERGED (what reverseMerge un-merges). UUID-only refs (equal subject_a/_b);
  // no extra FK relation. Null unless resolution_action = MERGE.
  surviving_subject_id String? @db.Uuid
  merged_subject_id    String? @db.Uuid

  // ---- Reversal audit (R2/R5) — set when a MERGED advisory is un-merged → REVERSED.
  reversed_by            String?
  reversed_at            DateTime? @db.Timestamptz
  reversal_justification String?

  // ---- TR-2a-B2 re-open provenance (DDR-2 §5) — set when a DISMISSED advisory is
  // re-opened by a strictly-stronger re-match (shared-ref count up OR a new
  // confirmed_kinds entry). The reviewer must see it is a re-open, not a fresh
  // pair. New contradictions / corroborator conflicts do NOT re-open. Nullable.
  reopened_at        DateTime? @db.Timestamptz
  reopened_from_band String?

  subject_a ResolutionSubject @relation("MatchAdvisorySubjectA", fields: [subject_a_id], references: [id])
  subject_b ResolutionSubject @relation("MatchAdvisorySubjectB", fields: [subject_b_id], references: [id])

  // One advisory per tenant-scoped unordered pair — the idempotency key (backfill /
  // re-run upserts, never duplicates).
  @@unique([tenant_id, subject_a_id, subject_b_id])
  @@index([tenant_id, status])
  @@index([subject_a_id])
  @@index([subject_b_id])
  @@schema("talent_trust")
}
