{
  "name": "talent-extraction",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/talent-extraction/src",
  "projectType": "library",
  "tags": ["scope:cip"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/talent-extraction",
        "main": "libs/talent-extraction/src/index.ts",
        "tsConfig": "libs/talent-extraction/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/talent-extraction/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests --root libs/talent-extraction"
      }
    }
  }
}
