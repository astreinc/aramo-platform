// Per-module Prisma schema for the `requisition` module — PR-A3 (ATS Batch 2).
//
// Per Architecture v2.0/v2.1 §7.1 (Schema-per-Module data architecture)
// and doc/05-conventions.md "Database Conventions". Cross-schema
// references UUID-only, no FK (§7.3).
//
// PR-A3 Gate 5 — second ATS-domain batch. Follows the PR-A2 pattern of
// record (libs/company exemplar; the A2 close §3): leaf lib, schema-per-
// module, row shape `id/tenant_id/site_id?/timestamps`, indexes lead
// with tenant_id, lazy-validation PrismaService, no metering/event-log/
// outbox (reference CRUD).
//
// A3-specific concept: the **assignment-visibility filter** (directive
// Ruling 2). RequisitionAssignment is the join row that drives the
// recruiter's per-row visibility predicate. Visibility is a QUERY
// PREDICATE applied in the repository LIST + GET-by-id paths — NOT a
// guard rejection. `requisition:read` (recruiter) sees only assigned
// rows; `requisition:read:all` (tenant_admin) sees every row.
//
// Status is a simple stored enum (directive §4 — explicitly NOT the
// pipeline state machine; no transition rules, no event log, no
// `openings_available` decrement on placement — those belong to A5).
//
// Cross-schema logical references (UUID-only, no FK per §7.3):
//   - company_id            → company.Company
//   - contact_id            → contact.Contact
//   - company_department_id → company.CompanyDepartment
//   - recruiter_id          → identity.User (informational provenance —
//                             the original recruiter who entered the
//                             req; NOT used for visibility — that's
//                             driven by RequisitionAssignment per
//                             Ruling 1: multi-recruiter assignment via
//                             the join, not single-recruiter column).
//   - owner_id              → identity.User
//   - entered_by_id         → identity.User
//   - RequisitionAssignment.user_id → identity.User
//   - RequisitionAssignment.assigned_by_id → identity.User

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["requisition"]
}

// RequisitionStatus — directive §4: a simple stored enum, recruiter-
// editable via `requisition:edit`. NO transition rules; NO state-machine
// trigger; NO event log. The pipeline state machine (Active→Placed→
// openings decrement) lives at A5 — this enum is a status label, not a
// workflow.
enum RequisitionStatus {
  active
  on_hold
  full
  closed
  canceled
  lead

  @@schema("requisition")
}

// RatePeriod — Compensation-Field Modeling v1.1 §2.1. Discrete period
// for pay_rate / bill_rate. The derived-view compute (margin_amount,
// markup_percent, margin_percent in projectView) requires bill + pay
// to share the same period (else the views return null per v1.1 §2.2
// guard + proof 13). NOT used for the perm path (placement_fee_*,
// salary_*) — those are flat numbers, not period-rated.
enum RatePeriod {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  ANNUAL

  @@schema("requisition")
}

// RequisitionCompensationModel — v1.1 §2.3 discriminator. CONTRACT
// uses bill/pay rates + the derived views; PERMANENT uses placement_fee
// + structured salary. Both shapes COEXIST on Requisition (the
// irrelevant fields stay null) — one migration covers both, per the
// PO's "include now" rationale (avoids a second perm migration later).
enum RequisitionCompensationModel {
  CONTRACT
  PERMANENT

  @@schema("requisition")
}

// Requisition — the ATS-domain job-order entity. OpenCATS doc-04 field
// shapes; greenfield port with the canonical Aramo tenant + site axes
// added.
model Requisition {
  // Identity.
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  site_id   String? @db.Uuid

  // Required identification.
  title String

  // Cross-schema logical references (Architecture §7.3 — UUID-only, no FK).
  company_id            String  @db.Uuid
  contact_id            String? @db.Uuid
  company_department_id String? @db.Uuid

  // Status (simple stored enum — directive §4).
  status RequisitionStatus @default(active)

  // Job-order metadata.
  type        String?
  duration    String?
  // Legacy free-text comp fields. Compensation-Field Modeling v1.1 §6
  // — COEXIST + deprecated; the structured successors live below
  // (pay_rate_amount/bill_rate_amount supersede rate_max; salary_amount
  // supersedes salary). A later cleanup PR drops these after the
  // frontend migration window closes.
  rate_max    String?
  salary      String?
  description String?
  notes       String?
  is_hot      Boolean @default(false)

  // Compensation-Field Modeling v1.1 §2 — the structured comp surface.
  // All fields optional (`?`) so the existing rows + the maskability
  // contract (v1.1 §3) work: D5 omits a field → undefined; the
  // discriminator gates which fields are meaningful at the application
  // layer (a CONTRACT req leaves placement_fee_*/salary_* null; a
  // PERMANENT req leaves bill_rate_*/pay_rate_* null). Currency is a
  // String? guarded at the controller boundary against a closed
  // ISO-4217 allowlist (v1.0 §2.3 — NOT an enum, to avoid migration
  // churn when the allowlist evolves).

  // §2.3 discriminator — CONTRACT or PERMANENT.
  compensation_model RequisitionCompensationModel?

  // §2.1 — the two stored facts (CONTRACT). The derived views
  // (margin_amount, markup_percent, margin_percent) are computed-on-
  // read in projectView (NOT stored — §2.2 + §10 halt).
  pay_rate_amount   Decimal?    @db.Decimal(12, 2)
  pay_rate_currency String?
  pay_rate_period   RatePeriod?

  bill_rate_amount   Decimal?    @db.Decimal(12, 2)
  bill_rate_currency String?
  bill_rate_period   RatePeriod?

  // §2.3 — PERMANENT-side fields. placement_fee_percent and
  // placement_fee_amount MAY BOTH be set (one fee model vs the other,
  // or a hybrid) — the application doesn't constrain. salary_amount /
  // salary_currency is the structured successor to the legacy `salary`
  // free-text field (§6).
  placement_fee_percent Decimal? @db.Decimal(5, 2)
  placement_fee_amount  Decimal? @db.Decimal(12, 2)
  salary_amount         Decimal? @db.Decimal(12, 2)
  salary_currency       String?

  // Openings counts (stored fields; directive §4 — NO decrement logic
  // at this batch; the pipeline at A5 will own placement -> decrement).
  openings           Int @default(1)
  openings_available Int @default(1)

  start_date DateTime? @db.Timestamptz
  city       String?
  state      String?

  // Provenance — the recruiter who originally entered the req. This is
  // INFORMATIONAL ONLY; per Ruling 1 the visibility filter keys on the
  // RequisitionAssignment join (multi-recruiter), NOT on this column.
  recruiter_id  String? @db.Uuid
  owner_id      String? @db.Uuid
  entered_by_id String? @db.Uuid

  // PR-A8-1 — back-reference to the import batch that created this row
  // (NULL for rows created outside the import engine). Cross-schema
  // logical reference to import.ImportBatch.id (§7.3).
  import_batch_id String? @db.Uuid

  // Timestamps.
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Intra-schema relation to the assignment join.
  assignments RequisitionAssignment[]

  // Indexes — every query leads with tenant_id; the (tenant, status)
  // index serves the dominant "active reqs in tenant" filter.
  @@index([tenant_id, status])
  @@index([tenant_id, company_id])
  @@index([tenant_id, site_id])
  @@index([tenant_id, is_hot])
  @@index([tenant_id, import_batch_id])

  @@schema("requisition")
}

// RequisitionAssignment — the join that drives the visibility filter
// (Ruling 1: multi-recruiter assignment). Recruiters see a requisition
// iff there is a row here for (their requisition, their user_id).
// tenant_admin (`requisition:read:all`) sees every row regardless.
//
// Intra-schema FK to Requisition (conventional Prisma relation;
// cross-schema is the boundary per §7.3). user_id + assigned_by_id are
// cross-schema logical references (identity.User), kept UUID-only.
model RequisitionAssignment {
  // Identity.
  id        String @id @default(uuid()) @db.Uuid
  tenant_id String @db.Uuid

  // Parent requisition (intra-schema FK).
  requisition_id String      @db.Uuid
  requisition    Requisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)

  // The assigned recruiter (UUID-only logical ref to identity.User).
  // The visibility predicate matches this against AuthContext.sub.
  user_id String @db.Uuid

  // Provenance.
  assigned_at      DateTime @default(now()) @db.Timestamptz
  assigned_by_id   String?  @db.Uuid

  // Indexes — the dominant "all reqs assigned to user X in tenant T"
  // query (the visibility filter's read path).
  @@index([tenant_id, user_id])
  @@index([tenant_id, requisition_id])

  // One assignment per (req, user) — re-assigning the same user is a
  // no-op idempotent insert under ON CONFLICT DO NOTHING (handled in
  // the repository).
  @@unique([requisition_id, user_id])

  @@schema("requisition")
}
