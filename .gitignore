# Dependencies
node_modules/

# Build output
dist/
build/
out-tsc/
tmp/

# Nx
.nx/cache
.nx/workspace-data

# Coverage
coverage/

# Per-module Prisma generated clients (output = "../generated/client")
**/prisma/generated/

# Env
.env
.env.*
!.env.example

# Local dev stack (tools/local-stack.sh) — pids + app logs
.local-stack/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Local working artifacts (not program history)
doc/prompts/

# Logs
*.log
npm-debug.log*

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Pact
pact/logs/
pact/pacts/

# Aramo M4 PR-8 — Terraform IaC ignore patterns
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
# Note: .terraform.lock.hcl files ARE committed (per Ruling 6).
# Note: *.tfvars.example files ARE committed (per §4.6).

# Recruiter-console live e2e (real session artifacts + Playwright output — never commit)
apps/ats-web/e2e/.auth/
apps/ats-web/test-results/
apps/ats-web/playwright-report/

# Uncommitted recon/report scratch (non-product)
scratch/
